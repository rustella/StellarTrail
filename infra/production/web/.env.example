# Copy to .env on the production server and keep the real file ignored by Git.
STELLARTAIL_WEB_IMAGE=ghcr.io/rustella/stellartrail-web:latest
STELLARTAIL_EDGE_NETWORK=stellartail-edge
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_WEB_RULE=Host(`app.example.invalid`) || Host(`app-alt1.example.invalid`) || Host(`app-alt2.example.invalid`)
VITE_STELLARTRAIL_API_BASE_URL=https://api.example.invalid
VITE_STELLARTRAIL_REQUEST_SIGNATURE_APP_ID=example-prod-web-client-id
VITE_STELLARTRAIL_REQUEST_SIGNATURE_APP_SECRET=example-prod-web-client-secret

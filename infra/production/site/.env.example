# Copy to .env on the production server and keep the real file ignored by Git.
STELLARTAIL_SITE_IMAGE=ghcr.io/rustella/stellartrail-site:latest
STELLARTAIL_EDGE_NETWORK=stellartail-edge
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_SITE_RULE=Host(`site.example.invalid`) || Host(`site-alt1.example.invalid`) || Host(`site-alt2.example.invalid`)
TRAEFIK_SITE_WWW_RULE=Host(`www.example.invalid`)

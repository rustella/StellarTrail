# Copy to .env on the production server and keep the real file ignored by Git.
STELLARTAIL_API_IMAGE=ghcr.io/rustella/stellartrail-api:latest
STELLARTAIL_EDGE_NETWORK=stellartail-edge
STELLARTAIL_BACKEND_NETWORK=stellartail-backend
STELLARTAIL_DEPLOY_ROOT=/www/service/stellartail
RUST_LOG=stellartrail_api=info,tower_http=info

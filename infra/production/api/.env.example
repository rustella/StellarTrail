# Copy to .env on the production server and keep the real file ignored by Git.
# This single env file configures the API service and its private PostgreSQL, Redis, and MinIO dependencies.
STELLARTAIL_API_IMAGE=ghcr.io/rustella/stellartrail-api:latest
STELLARTAIL_EDGE_NETWORK=stellartail-edge
STELLARTAIL_BACKEND_NETWORK=stellartail-backend
STELLARTAIL_DEPLOY_ROOT=/www/service/stellartail
RUST_LOG=stellartrail_api=info,tower_http=info
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-04-22T22-12-26Z
MINIO_MC_IMAGE=quay.io/minio/mc:RELEASE.2025-04-16T18-13-26Z
POSTGRES_USER=stellartrail
POSTGRES_DB=stellartrail
POSTGRES_PASSWORD=***
REDIS_PASSWORD=***
MINIO_ROOT_USER=stellartrail
MINIO_ROOT_PASSWORD=***
OBJECT_STORAGE_BUCKET=stellartrail-uploads
KNOTS_MEDIA_BUCKET=stellartrail-knots-media

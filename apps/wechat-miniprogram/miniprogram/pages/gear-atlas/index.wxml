<view class="atlas-page {{themeClass}}">
  <view class="hero-card">
    <view>
      <view class="eyebrow">{{copy.eyebrow}}</view>
      <view class="hero-title">{{copy.title}}</view>
      <view class="hero-subtitle">{{copy.subtitle}}</view>
    </view>
    <button class="primary-action" bindtap="goSubmit">{{copy.submit}}</button>
  </view>

  <view wx:if="{{offlineNotice}}" class="offline-notice"
    >{{offlineNotice}}</view
  >

  <view class="search-card">
    <input
      class="search-input"
      value="{{q}}"
      placeholder="{{copy.searchPlaceholder}}"
      confirm-type="search"
      bindinput="onSearchInput"
      bindconfirm="submitSearch"
    />
    <button class="search-button" bindtap="submitSearch">
      {{copy.search}}
    </button>
    <button wx:if="{{q}}" class="clear-button" bindtap="clearSearch">
      {{copy.clear}}
    </button>
  </view>

  <scroll-view class="category-scroll" scroll-x enable-flex>
    <block wx:for="{{categories}}" wx:key="id">
      <view
        class="category-chip {{selectedCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectCategory"
      >
        {{item.label}}
      </view>
    </block>
  </scroll-view>

  <view
    wx:if="{{error}}"
    class="{{errorIsUnavailable ? 'state-card' : 'error-card'}}"
  >
    <view>{{error}}</view>
    <button bindtap="refreshPage">重试</button>
  </view>

  <block wx:else>
    <view wx:if="{{loading}}" class="state-card">{{copy.loading}}</view>
    <view wx:elif="{{!items.length}}" class="empty-card">
      <view class="empty-title">{{copy.emptyTitle}}</view>
      <view class="empty-subtitle">{{copy.emptySubtitle}}</view>
      <button class="primary-action wide" bindtap="goSubmit">
        {{copy.emptyAction}}
      </button>
    </view>
    <view wx:else class="atlas-list">
      <block wx:for="{{items}}" wx:key="id">
        <view class="atlas-card" data-id="{{item.id}}" bindtap="goDetail">
          <view class="card-topline">
            <view class="category-badge">{{item.categoryText}}</view>
            <view class="atlas-status">{{copy.status}}</view>
          </view>
          <view class="atlas-name">{{item.name}}</view>
          <view class="atlas-meta">{{item.brandModelText}}</view>
          <view class="atlas-desc">{{item.descriptionText}}</view>
          <view class="metrics-row">
            <view class="metric">
              <view class="metric-value">{{item.weightText}}</view>
              <view class="metric-label">{{copy.weight}}</view>
            </view>
            <view class="metric">
              <view class="metric-value">{{item.officialPriceText}}</view>
              <view class="metric-label">{{copy.officialPrice}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
    <view wx:if="{{loadingMore}}" class="load-more">{{copy.loadingMore}}</view>
    <view wx:elif="{{items.length && !nextCursor}}" class="load-more muted"
      >{{copy.noMore}}</view
    >
  </block>
</view>

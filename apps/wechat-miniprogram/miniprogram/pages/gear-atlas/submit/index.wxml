<view class="form-page {{themeClass}}">
  <view wx:if="{{requiresLogin}}" class="state-card login-required-card">
    <view class="login-required-title">登录后投稿装备</view>
    <view class="login-required-desc"
      >装备图鉴投稿需要进入审核，通过后才会展示在公共图鉴。</view
    >
    <button bindtap="loginPromptGoLogin">去登录</button>
  </view>

  <block wx:else>
    <view wx:if="{{error}}" class="error-card">{{error}}</view>

    <view class="intro-card">
      <view class="intro-title">投稿到装备图鉴</view>
      <view class="intro-subtitle"
        >只填写公开参数，审核通过后会出现在装备图鉴。</view
      >
    </view>

    <view class="form-card">
      <view class="section-title">基本信息</view>
      <picker
        value="{{categoryIndex}}"
        range="{{categoryLabels}}"
        bindchange="onCategoryChange"
      >
        <view class="picker-row">
          <view>
            <view class="field-label required">装备分类</view>
            <view class="field-value">{{categoryLabels[categoryIndex]}}</view>
            <view class="field-hint">{{categoryHints[categoryIndex]}}</view>
          </view>
          <view class="chevron">›</view>
        </view>
      </picker>
      <view class="field">
        <view class="field-label required">装备名称</view>
        <input
          value="{{form.name}}"
          data-field="name"
          placeholder="例如 NITECORE 头灯"
          bindinput="onInput"
        />
      </view>
      <view class="two-column">
        <view class="field compact">
          <view class="field-label">品牌</view>
          <input
            value="{{form.brand}}"
            data-field="brand"
            placeholder="品牌"
            bindinput="onInput"
          />
        </view>
        <view class="field compact">
          <view class="field-label">型号</view>
          <input
            value="{{form.model}}"
            data-field="model"
            placeholder="型号"
            bindinput="onInput"
          />
        </view>
      </view>
      <view class="field">
        <view class="field-label">装备描述</view>
        <textarea
          value="{{form.description}}"
          data-field="description"
          placeholder="适用场景、亮点或公开参数说明"
          bindinput="onInput"
        />
      </view>
    </view>

    <view class="form-card">
      <view class="section-title">公开参数</view>
      <view class="two-column">
        <view class="field compact">
          <view class="field-label">重量</view>
          <view class="spec-input-row">
            <input
              value="{{form.weightText}}"
              data-field="weightText"
              type="digit"
              placeholder="例如 0.315"
              bindinput="onInput"
            />
            <picker
              value="{{weightUnitIndex}}"
              range="{{weightUnitLabels}}"
              bindchange="onWeightUnitChange"
            >
              <view class="unit-picker"
                >{{weightUnitOptions[weightUnitIndex].label}} ›</view
              >
            </picker>
          </view>
        </view>
        <view class="field compact">
          <view class="field-label">官方价格</view>
          <view class="price-input-row">
            <input
              value="{{form.officialPriceText}}"
              data-field="officialPriceText"
              type="digit"
              placeholder="699"
              bindinput="onInput"
            />
            <picker
              value="{{officialPriceCurrencyIndex}}"
              range="{{currencyLabels}}"
              bindchange="onOfficialPriceCurrencyChange"
            >
              <view class="currency-picker"
                >{{currencyOptions[officialPriceCurrencyIndex].value}} ›</view
              >
            </picker>
          </view>
        </view>
      </view>
      <view class="spec-grid">
        <view wx:for="{{specFields}}" wx:key="key" class="field spec-field">
          <view class="field-label">{{item.label}}</view>
          <view class="spec-input-row">
            <input
              wx:if="{{!item.choiceOnly}}"
              value="{{item.valueText}}"
              data-key="{{item.key}}"
              data-index="{{index}}"
              type="{{item.inputType === 'number' ? 'digit' : 'text'}}"
              placeholder="{{item.placeholder}}"
              bindinput="onSpecInput"
            />
            <view
              wx:else
              class="choice-value {{item.unitLabel ? '' : 'placeholder'}}"
              >{{item.unitLabel || item.placeholder}}</view
            >
            <picker
              wx:if="{{item.units && item.units.length > 0}}"
              value="{{item.unitIndex}}"
              range="{{item.unitLabels}}"
              data-key="{{item.key}}"
              data-index="{{index}}"
              bindchange="onSpecUnitChange"
            >
              <view class="unit-picker"
                >{{item.choiceOnly ? (item.unitLabel || '选择') :
                (item.unitLabel || '无单位')}} ›</view
              >
            </picker>
          </view>
        </view>
      </view>
    </view>

    <view class="form-actions">
      <button class="secondary" bindtap="cancel">取消</button>
      <button class="primary" loading="{{submitting}}" bindtap="submitForm">
        提交审核
      </button>
    </view>
  </block>

  <view wx:if="{{loginPrompt.visible}}" class="login-prompt-mask">
    <view class="login-prompt-card">
      <view class="login-prompt-close" bindtap="loginPromptClose">×</view>
      <view class="login-prompt-title">{{loginPrompt.title}}</view>
      <view class="login-prompt-message">{{loginPrompt.message}}</view>
      <view class="login-prompt-actions">
        <button class="secondary" bindtap="loginPromptClose">暂不登录</button>
        <button class="primary" bindtap="loginPromptGoLogin">去登录</button>
      </view>
    </view>
  </view>
</view>

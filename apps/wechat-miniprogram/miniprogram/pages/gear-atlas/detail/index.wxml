<view class="atlas-detail-page {{themeClass}}">
  <view wx:if="{{offlineNotice}}" class="offline-notice"
    >{{offlineNotice}}</view
  >

  <view wx:if="{{error}}" class="state-card error">
    <view>{{error}}</view>
    <button bindtap="loadDetail">{{copy.retry}}</button>
  </view>

  <view wx:elif="{{loading && !item}}" class="state-card"
    >{{copy.loading}}</view
  >

  <view wx:elif="{{!item}}" class="state-card">{{copy.empty}}</view>

  <block wx:else>
    <view class="detail-hero">
      <view class="badge-row">
        <view class="category-badge">{{categoryText}}</view>
        <view class="atlas-status">{{copy.status}}</view>
      </view>
      <view class="detail-title">{{item.name}}</view>
      <view class="detail-subtitle">{{brandModelText}}</view>
      <view class="summary-grid">
        <view class="summary-item">
          <view class="summary-value">{{weightText}}</view>
          <view class="summary-label">{{copy.weight}}</view>
        </view>
        <view class="summary-item">
          <view class="summary-value">{{officialPriceText}}</view>
          <view class="summary-label">{{copy.officialPrice}}</view>
        </view>
        <view class="summary-item">
          <view class="summary-value">{{approvedAtText}}</view>
          <view class="summary-label">{{copy.approvedAt}}</view>
        </view>
      </view>
    </view>

    <block wx:for="{{groups}}" wx:key="title">
      <view class="info-card">
        <view class="section-title">{{item.title}}</view>
        <block wx:for="{{item.items}}" wx:key="label" wx:for-item="row">
          <view class="info-row">
            <view class="info-label">{{row.label}}</view>
            <view class="info-value">{{row.value}}</view>
          </view>
        </block>
      </view>
    </block>
  </block>
</view>

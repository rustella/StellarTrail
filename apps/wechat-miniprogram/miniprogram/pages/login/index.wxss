.login-page {
  min-height: 100vh;
  padding: 32rpx;
  background: var(--page-bg);
  color: var(--text-color);
  box-sizing: border-box;
}

.login-page.theme-dark {
  background: var(--body-gradient);
}

.login-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 30rpx;
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.login-card.hero {
  color: #ffffff;
  background: var(--hero-gradient);
  box-shadow: var(--shadow-card);
}

.eyebrow {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.title {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.35;
}

.subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  line-height: 1.58;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.status-title {
  color: var(--text-color);
  font-size: 30rpx;
  font-weight: 900;
}

.status-desc {
  margin-top: 8rpx;
  color: var(--muted-color);
  font-size: 25rpx;
}

.status-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: var(--status-warning-text);
  background: var(--status-warning-bg);
  font-size: 22rpx;
  font-weight: 900;
}

.status-badge.success {
  color: var(--status-success-text);
  background: var(--status-success-bg);
}

.error-text {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
  font-size: 24rpx;
  line-height: 1.5;
}

button.primary,
button.secondary {
  width: 100%;
  margin-top: 24rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 82rpx;
}

button.primary {
  color: var(--brand-text-color);
  background: var(--brand-color);
}

button.secondary {
  color: var(--soft-control-text);
  background: var(--soft-control-bg);
}

<view class="container {{themeClass}}">
  <view class="card">
    <view class="title">我的寻径星野</view>
    <view class="subtitle">管理装备、学习技能，也可以切换黑夜模式。</view>
  </view>

  <view class="card account-card">
    <view class="account-main">
      <button
        wx:if="{{loggedIn}}"
        class="account-avatar"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseWechatAvatar"
        disabled="{{avatarLoading}}"
        aria-label="导入微信头像"
      >
        <image
          wx:if="{{accountProfile.avatarUrl}}"
          class="account-avatar-image"
          src="{{accountProfile.avatarUrl}}"
          mode="aspectFill"
        />
        <text wx:else>{{accountProfile.avatarInitial}}</text>
      </button>
      <view class="account-copy">
        <view class="account-title">账号状态</view>
        <view wx:if="{{loggedIn}}" class="account-name-row">
          <view class="account-desc">{{accountProfile.displayName}}</view>
          <button class="account-inline-button" bindtap="openNicknameModal">
            修改名称
          </button>
        </view>
        <view class="account-hint"
          >{{loggedIn ? '可以管理自己的装备清单。' :
          '未登录也可以先看装备图鉴和绳结教学。'}}</view
        >
        <view wx:if="{{loggedIn}}" class="account-email-row">
          <view class="account-email-text">{{accountProfile.emailText}}</view>
          <button
            wx:if="{{!accountProfile.hasEmail}}"
            class="account-inline-button"
            bindtap="openEmailBindingModal"
          >
            绑定邮箱
          </button>
        </view>
        <view wx:if="{{accountError}}" class="account-error"
          >{{accountError}}</view
        >
      </view>
    </view>
    <button wx:if="{{!loggedIn}}" class="account-button" bindtap="goLogin">
      登录 / 注册
    </button>
    <button wx:else class="account-button danger" bindtap="logout">退出</button>
  </view>

  <view class="card theme-settings-card">
    <view>
      <view class="theme-settings-title">黑夜模式</view>
      <view class="theme-settings-desc"
        >开启后切换为紫色星空暗色界面，夜间浏览更舒服。</view
      >
    </view>
    <button
      class="theme-toggle"
      aria-pressed="{{isDarkTheme}}"
      aria-label="{{themeToggleAriaLabel}}"
      bindtap="toggleTheme"
    >
      <text class="theme-toggle-icon">{{themeToggleIcon}}</text
      >{{themeToggleText}}
    </button>
  </view>

  <view wx:if="{{nicknameModalVisible}}" class="profile-modal-mask">
    <view class="profile-modal-card">
      <view class="profile-modal-title">修改名称</view>
      <form class="profile-name-form" bindsubmit="saveWechatNickname">
        <input
          class="profile-name-input"
          name="nickname"
          type="nickname"
          placeholder="点这里后，在下方选择“用微信昵称”"
          value="{{nicknameDraft}}"
          disabled="{{nicknameLoading}}"
          confirm-type="done"
          bindinput="onNicknameInput"
          bindnicknamereview="onWechatNicknameReview"
        />
        <view wx:if="{{accountError}}" class="profile-modal-error"
          >{{accountError}}</view
        >
        <view class="profile-modal-actions">
          <button
            class="account-inline-button"
            loading="{{nicknameLoading}}"
            form-type="submit"
          >
            保存
          </button>
        </view>
      </form>
      <view class="profile-modal-footer">
        <button
          class="account-inline-button muted"
          disabled="{{nicknameLoading}}"
          bindtap="closeNicknameModal"
        >
          取消
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{emailBindingModalVisible}}" class="profile-modal-mask">
    <view class="profile-modal-card">
      <view class="profile-modal-title">绑定邮箱</view>
      <view class="profile-modal-desc"
        >绑定后可用邮箱登录，也可以找回密码。</view
      >
      <view class="profile-email-form">
        <input
          class="profile-name-input"
          type="text"
          placeholder="邮箱"
          value="{{emailBindingEmail}}"
          data-field="emailBindingEmail"
          disabled="{{emailCodeLoading || emailBindingLoading}}"
          confirm-type="next"
          bindinput="onEmailBindingInput"
        />
        <view class="profile-email-code-row">
          <input
            class="profile-name-input profile-email-code-input"
            type="text"
            placeholder="邮箱验证码"
            value="{{emailBindingCode}}"
            data-field="emailBindingCode"
            disabled="{{emailBindingLoading}}"
            confirm-type="done"
            bindinput="onEmailBindingInput"
          />
          <button
            class="account-inline-button"
            loading="{{emailCodeLoading}}"
            disabled="{{emailBindingLoading}}"
            bindtap="sendEmailBindingCode"
          >
            获取验证码
          </button>
        </view>
        <view wx:if="{{emailBindingNotice}}" class="profile-modal-notice"
          >{{emailBindingNotice}}</view
        >
        <view wx:if="{{accountError}}" class="profile-modal-error"
          >{{accountError}}</view
        >
        <view class="profile-modal-actions">
          <button
            class="account-inline-button profile-modal-action-button"
            loading="{{emailBindingLoading}}"
            bindtap="submitEmailBinding"
          >
            确定
          </button>
          <button
            class="account-inline-button muted profile-modal-action-button"
            disabled="{{emailCodeLoading || emailBindingLoading}}"
            bindtap="closeEmailBindingModal"
          >
            取消
          </button>
        </view>
      </view>
    </view>
  </view>
</view>

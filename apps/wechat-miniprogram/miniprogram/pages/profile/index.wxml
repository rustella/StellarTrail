<view class="container {{themeClass}}">
  <view class="card">
    <view class="title">我的寻径星野</view>
    <view class="subtitle">管理装备、学习技能，也可以切换黑夜模式。</view>
  </view>

  <view class="card account-card">
    <view class="account-main">
      <button
        wx:if="{{loggedIn}}"
        class="account-avatar"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseWechatAvatar"
        disabled="{{avatarLoading}}"
        aria-label="导入微信头像"
      >
        <image
          wx:if="{{accountProfile.avatarUrl}}"
          class="account-avatar-image"
          src="{{accountProfile.avatarUrl}}"
          mode="aspectFill"
        />
        <text wx:else>{{accountProfile.avatarInitial}}</text>
      </button>
      <view class="account-copy">
        <view class="account-title">账号状态</view>
        <view wx:if="{{loggedIn}}" class="account-name-row">
          <input
            wx:if="{{nicknameEditing}}"
            class="account-nickname-input"
            type="nickname"
            placeholder="微信昵称"
            value="{{nicknameDraft}}"
            disabled="{{nicknameLoading}}"
            bindinput="onNicknameInput"
          />
          <view wx:else class="account-desc"
            >{{accountProfile.displayName}}</view
          >
          <button
            wx:if="{{!nicknameEditing}}"
            class="account-inline-button"
            bindtap="startNicknameEdit"
          >
            {{accountProfile.hasNickname ? '修改' : '导入昵称'}}
          </button>
          <block wx:else>
            <button
              class="account-inline-button"
              loading="{{nicknameLoading}}"
              bindtap="saveNickname"
            >
              保存
            </button>
            <button
              class="account-inline-button muted"
              disabled="{{nicknameLoading}}"
              bindtap="cancelNicknameEdit"
            >
              取消
            </button>
          </block>
        </view>
        <view class="account-hint"
          >{{loggedIn ? '可以管理自己的装备清单。' :
          '未登录也可以先看出行装备参考和绳结教学。'}}</view
        >
        <view wx:if="{{accountError}}" class="account-error"
          >{{accountError}}</view
        >
      </view>
    </view>
    <button wx:if="{{!loggedIn}}" class="account-button" bindtap="goLogin">
      登录 / 注册
    </button>
    <button wx:else class="account-button danger" bindtap="logout">退出</button>
  </view>

  <view class="card theme-settings-card">
    <view>
      <view class="theme-settings-title">黑夜模式</view>
      <view class="theme-settings-desc"
        >开启后切换为紫色星空暗色界面，夜间浏览更舒服。</view
      >
    </view>
    <button
      class="theme-toggle"
      aria-pressed="{{isDarkTheme}}"
      aria-label="{{themeToggleAriaLabel}}"
      bindtap="toggleTheme"
    >
      <text class="theme-toggle-icon">{{themeToggleIcon}}</text
      >{{themeToggleText}}
    </button>
  </view>
</view>

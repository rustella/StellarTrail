.container {
  padding-top: 40rpx;
}

.account-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.account-main {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 20rpx;
}

.account-avatar {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 96rpx;
  text-align: center;
  overflow: hidden;
}

.account-avatar-image {
  width: 96rpx;
  height: 96rpx;
}

.account-copy {
  min-width: 0;
}

.account-title {
  color: var(--text-color);
  font-size: 30rpx;
  font-weight: 900;
}

.account-desc {
  margin-top: 8rpx;
  color: var(--heading-muted-color);
  font-size: 26rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-hint {
  margin-top: 6rpx;
  color: var(--muted-color);
  font-size: 23rpx;
  line-height: 1.5;
}

.account-error {
  margin-top: 8rpx;
  color: var(--status-danger-text);
  font-size: 22rpx;
  line-height: 1.4;
}

.account-button {
  flex: 0 0 auto;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 70rpx;
}

.account-button.danger {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
}

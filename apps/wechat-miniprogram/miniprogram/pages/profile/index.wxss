.container {
  padding-top: 40rpx;
}

.account-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.account-main {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 20rpx;
}

.account-avatar {
  position: relative;
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 96rpx;
  text-align: center;
  overflow: hidden;
}

.account-avatar::after {
  border: 0;
}

.account-avatar-image {
  width: 96rpx;
  height: 96rpx;
}

.account-copy {
  min-width: 0;
}

.account-title {
  color: var(--text-color);
  font-size: 30rpx;
  font-weight: 900;
}

.account-desc {
  min-width: 0;
  color: var(--heading-muted-color);
  font-size: 26rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-name-row {
  display: flex;
  align-items: center;
  min-width: 0;
  margin-top: 8rpx;
  gap: 12rpx;
}

.account-inline-button {
  flex: 0 0 auto;
  margin: 0;
  padding: 0 16rpx;
  border: 1rpx solid var(--control-border);
  border-radius: 999rpx;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.account-inline-button::after {
  border: 0;
}

.account-inline-button.muted {
  color: var(--soft-control-text);
  background: var(--soft-control-bg);
}

.account-hint {
  margin-top: 6rpx;
  color: var(--muted-color);
  font-size: 23rpx;
  line-height: 1.5;
}

.account-error {
  margin-top: 8rpx;
  color: var(--status-danger-text);
  font-size: 22rpx;
  line-height: 1.4;
}

.account-button {
  flex: 0 0 auto;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 70rpx;
}

.account-button.danger {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
}

.profile-modal-mask {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.42);
  box-sizing: border-box;
}

.profile-modal-card {
  width: 100%;
  padding: 30rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 28rpx;
  background: var(--surface-color);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.profile-modal-title {
  color: var(--text-color);
  font-size: 32rpx;
  font-weight: 900;
}

.profile-name-methods {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.profile-name-method {
  margin: 0;
  padding: 0 24rpx;
  border: 1rpx solid var(--control-border);
  border-radius: 18rpx;
  color: var(--text-color);
  background: var(--control-bg);
  font-size: 27rpx;
  font-weight: 900;
  line-height: 88rpx;
  text-align: left;
}

.profile-name-method::after {
  border: 0;
}

.profile-name-form {
  margin-top: 24rpx;
}

.profile-name-input {
  width: 100%;
  height: 78rpx;
  padding: 0 22rpx;
  border: 1rpx solid var(--control-border);
  border-radius: 18rpx;
  color: var(--text-color);
  background: var(--control-bg);
  font-size: 27rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.profile-modal-error {
  margin-top: 14rpx;
  color: var(--status-danger-text);
  font-size: 23rpx;
  line-height: 1.4;
}

.profile-modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 24rpx;
}

.profile-modal-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

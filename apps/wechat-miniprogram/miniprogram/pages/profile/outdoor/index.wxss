.outdoor-profile-page {
  min-height: 100vh;
  padding: 28rpx;
  background: var(--page-bg);
  box-sizing: border-box;
}

.outdoor-hero,
.state-card,
.form-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.outdoor-hero {
  margin-top: 0;
}

.eyebrow {
  color: var(--brand-color);
  font-size: 24rpx;
  font-weight: 900;
}

.title,
.state-title {
  margin-top: 10rpx;
  color: var(--text-color);
  font-weight: 900;
}

.title {
  font-size: 40rpx;
}

.state-title {
  font-size: 32rpx;
}

.subtitle,
.state-desc,
.state-line {
  margin-top: 10rpx;
  color: var(--muted-color);
  font-size: 25rpx;
  line-height: 1.5;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.field-label {
  margin-top: 20rpx;
  color: var(--muted-color);
  font-size: 24rpx;
  font-weight: 800;
}

input,
textarea,
.picker-value {
  width: 100%;
  margin-top: 12rpx;
  padding: 0 20rpx;
  border-radius: var(--card-inner-radius);
  color: var(--text-color);
  background: var(--control-bg);
  font-size: 26rpx;
  box-sizing: border-box;
}

input,
.picker-value {
  min-height: 76rpx;
  line-height: 76rpx;
}

.inline-clear-button {
  display: inline-flex;
  min-height: 52rpx;
  margin-top: 14rpx;
  padding: 0 18rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.inline-clear-button::after {
  border: 0;
}

textarea {
  min-height: 150rpx;
  padding-top: 18rpx;
  line-height: 1.45;
}

.primary-button {
  width: 100%;
  margin-top: 28rpx;
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 82rpx;
}

.primary-button::after {
  border: 0;
}

.error-line {
  margin-bottom: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: var(--card-inner-radius);
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
  font-size: 24rpx;
  line-height: 1.4;
}

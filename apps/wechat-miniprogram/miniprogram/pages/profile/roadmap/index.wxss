.roadmap-page {
  min-height: 100vh;
  padding: 32rpx;
  background: var(--body-gradient);
  box-sizing: border-box;
}

.roadmap-hero {
  padding: 34rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.roadmap-eyebrow {
  color: var(--brand-soft-text);
  font-size: 22rpx;
  font-weight: 900;
}

.roadmap-title {
  margin-top: 8rpx;
  color: var(--text-color);
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.2;
}

.roadmap-subtitle {
  margin-top: 12rpx;
  color: var(--muted-color);
  font-size: 25rpx;
  line-height: 1.55;
}

.offline-notice {
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: var(--card-inner-radius);
  color: var(--status-warning-text);
  background: var(--status-warning-bg);
  font-size: 23rpx;
  font-weight: 800;
}

.roadmap-filter-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.roadmap-filter-pill {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid var(--control-border);
  border-radius: 18rpx;
  color: var(--text-color);
  background: var(--control-bg);
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.roadmap-list {
  margin-top: 22rpx;
}

.roadmap-card {
  margin-top: 18rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.roadmap-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.roadmap-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.roadmap-category,
.roadmap-status,
.roadmap-priority {
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.roadmap-category {
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
}

.roadmap-status {
  color: var(--soft-control-text);
  background: var(--soft-control-bg);
}

.roadmap-status.status-building,
.roadmap-status.status-preview {
  color: var(--status-warning-text);
  background: var(--status-warning-bg);
}

.roadmap-status.status-shipped {
  color: var(--status-success-text);
  background: var(--status-success-bg);
}

.roadmap-priority {
  flex: 0 0 auto;
  color: var(--muted-color);
  background: var(--control-bg);
}

.roadmap-item-title {
  margin-top: 22rpx;
  color: var(--text-color);
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.3;
}

.roadmap-item-summary,
.roadmap-item-details {
  margin-top: 12rpx;
  color: var(--muted-color);
  font-size: 24rpx;
  line-height: 1.55;
}

.roadmap-item-details {
  color: var(--soft-control-text);
}

.roadmap-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 24rpx;
}

.roadmap-action-button {
  flex: 1;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid var(--brand-color);
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.roadmap-action-button::after {
  border: 0;
}

.roadmap-action-button.ghost {
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
}

.roadmap-action-button.active {
  border-color: var(--status-success-text);
  color: var(--status-success-text);
  background: var(--status-success-bg);
}

.roadmap-state-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  color: var(--muted-color);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
  font-size: 25rpx;
  line-height: 1.5;
}

.roadmap-state-card.error {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
}

.roadmap-state-card button {
  margin-top: 18rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 24rpx;
  font-weight: 900;
}

.roadmap-state-card button::after {
  border: 0;
}

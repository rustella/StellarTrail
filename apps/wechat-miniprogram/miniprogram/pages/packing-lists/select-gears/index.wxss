@import "../index.wxss";

.packing-page {
  padding-bottom: 150rpx;
}

.select-header,
.search-card,
.filter-panel,
.gear-select-card {
  margin-top: 24rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.select-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  background: var(--hero-surface-gradient);
}

.selected-count {
  display: grid;
  flex: 0 0 auto;
  min-width: 70rpx;
  height: 70rpx;
  place-items: center;
  border-radius: 50%;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 30rpx;
  font-weight: 900;
}

.search-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: 20rpx;
  color: var(--text-color);
  background: var(--control-bg);
  font-size: 26rpx;
}

.search-button,
.clear-button {
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.search-button {
  color: var(--brand-text-color);
  background: var(--brand-color);
}

.clear-button {
  color: var(--soft-control-text);
  background: var(--soft-control-bg);
}

.filter-panel {
  padding: 22rpx 0 18rpx;
}

.filter-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 22rpx 16rpx;
}

.filter-panel-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: var(--text-color);
  font-size: 28rpx;
  font-weight: 900;
}

.filter-panel-title::before {
  display: block;
  width: 8rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: var(--brand-color);
  content: "";
}

.filter-panel-hint {
  color: var(--muted-color);
  font-size: 22rpx;
  font-weight: 700;
}

.filter-section-label {
  padding: 0 22rpx;
  color: var(--heading-muted-color);
  font-size: 22rpx;
  font-weight: 900;
}

.category-scroll {
  display: flex;
  width: 100%;
  margin-top: 12rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  margin-right: 12rpx;
  padding: 14rpx 20rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: 999rpx;
  color: var(--soft-control-text);
  background: var(--control-bg);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.category-chip.active {
  border-color: var(--brand-color);
  color: var(--brand-color);
  background: var(--brand-soft-bg);
}

.filter-select-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
}

.filter-select-picker {
  min-width: 0;
}

.filter-select {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 10rpx;
  min-height: 76rpx;
  padding: 0 18rpx;
  overflow: hidden;
  border: 1rpx solid var(--soft-border-color);
  border-radius: 20rpx;
  color: var(--text-color);
  background: var(--control-bg);
  box-sizing: border-box;
}

.filter-label {
  color: var(--muted-color);
  font-size: 21rpx;
  font-weight: 900;
}

.filter-value {
  min-width: 0;
  overflow: hidden;
  color: var(--text-color);
  font-size: 25rpx;
  font-weight: 900;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-caret {
  color: var(--accent-color);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.gear-select-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
}

.select-dot {
  display: grid;
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  place-items: center;
  border: 3rpx solid var(--brand-color);
  border-radius: 50%;
  color: var(--brand-text-color);
  background: transparent;
  font-size: 26rpx;
  font-weight: 900;
}

.select-dot.active {
  background: var(--brand-color);
}

.gear-main {
  min-width: 0;
  flex: 1;
}

.gear-name {
  color: var(--text-color);
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.35;
}

.gear-meta {
  margin-top: 8rpx;
  color: var(--muted-color);
  font-size: 23rpx;
}

.gear-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.gear-tags text {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  color: var(--soft-control-text);
  background: var(--soft-control-bg);
  font-size: 21rpx;
}

.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-color);
  background: var(--footer-bg);
}

.submit-bar button {
  width: 100%;
  margin: 0;
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 82rpx;
}

<view class="packing-page {{themeClass}}">
  <view class="hero-card">
    <view>
      <view class="eyebrow">出发前准备</view>
      <view class="hero-title">打包清单</view>
      <view class="hero-subtitle"
        >按路线和徒步时长挑选个人装备，出发前逐项确认。</view
      >
    </view>
    <button class="primary-action" bindtap="goCreate">新建</button>
  </view>

  <view wx:if="{{offlineNotice}}" class="offline-notice"
    >{{offlineNotice}}</view
  >

  <view wx:if="{{!isLoggedIn}}" class="state-card login-required">
    <view class="state-title">登录后使用打包清单</view>
    <view class="state-desc"
      >清单会保存到你的账号里，方便不同路线重复准备。</view
    >
    <button bindtap="goLogin">登录</button>
  </view>

  <block wx:else>
    <view wx:if="{{error}}" class="state-card error">
      <view>{{error}}</view>
      <button bindtap="refreshPage">重试</button>
    </view>

    <view wx:elif="{{loading}}" class="state-card">正在加载打包清单...</view>

    <view wx:elif="{{!lists.length}}" class="state-card empty">
      <view class="state-title">还没有打包清单</view>
      <view class="state-desc"
        >例如“一日武功山”，只挑当天需要带的小包装备。</view
      >
      <button class="primary-action wide" bindtap="goCreate">
        新建第一份清单
      </button>
    </view>

    <view wx:else class="packing-list">
      <block wx:for="{{lists}}" wx:key="id">
        <view class="packing-card" data-id="{{item.id}}" bindtap="goDetail">
          <view class="card-header">
            <view>
              <view class="packing-name">{{item.name}}</view>
              <view class="packing-meta">{{item.metaText}}</view>
            </view>
            <view class="progress-pill">{{item.progressText}}</view>
          </view>
          <view class="metrics-row">
            <view class="metric">
              <view class="metric-value">{{item.item_count}}</view>
              <view class="metric-label">装备</view>
            </view>
            <view class="metric">
              <view class="metric-value">{{item.packed_count}}</view>
              <view class="metric-label">已打包</view>
            </view>
            <view class="metric">
              <view class="metric-value">{{item.weightText}}</view>
              <view class="metric-label">总重量</view>
            </view>
          </view>
          <view class="card-actions">
            <button catchtap="deleteList" data-id="{{item.id}}">删除</button>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{loadingMore}}" class="load-more">继续加载...</view>
    <view wx:elif="{{lists.length && !nextCursor}}" class="load-more muted"
      >没有更多清单了</view
    >
  </block>

  <view wx:if="{{loginPrompt.visible}}" class="login-prompt-mask">
    <view class="login-prompt-card">
      <view class="login-prompt-close" bindtap="loginPromptClose">×</view>
      <view class="login-prompt-title">{{loginPrompt.title}}</view>
      <view class="login-prompt-message">{{loginPrompt.message}}</view>
      <view class="login-prompt-actions">
        <button class="secondary" bindtap="loginPromptClose">暂不登录</button>
        <button class="primary" bindtap="loginPromptGoLogin">去登录</button>
      </view>
    </view>
  </view>
</view>

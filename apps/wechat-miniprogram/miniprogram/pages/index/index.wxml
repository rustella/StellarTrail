<view class="home-page {{themeClass}}">
  <view class="hero-card">
    <view class="hero-eyebrow">寻径星野 · 出发前检查</view>
    <view class="hero-title">今天准备好出发了吗？</view>
    <view class="hero-subtitle">先核对装备状态，再补一项户外技能。</view>
    <view class="hero-status-row">
      <view class="hero-status-pill">
        <text class="hero-status-dot"></text>
        <text>{{isLoggedIn ? '我的装备已保存' : '未登录也可先浏览'}}</text>
      </view>
    </view>
    <view class="hero-actions">
      <button class="hero-button primary" bindtap="goGears">检查装备</button>
      <button class="hero-button secondary" bindtap="goSkills">学习技能</button>
    </view>
  </view>

  <view wx:if="{{offlineNotice}}" class="offline-notice"
    >{{offlineNotice}}</view
  >

  <view class="quick-grid">
    <block wx:for="{{quickActions}}" wx:key="id">
      <view
        class="quick-card"
        data-target="{{item.target}}"
        bindtap="onQuickAction"
      >
        <view class="quick-icon">{{item.icon}}</view>
        <view class="quick-title">{{item.title}}</view>
        <view class="quick-desc">{{item.description}}</view>
      </view>
    </block>
  </view>

  <view class="section-card">
    <view class="section-header">
      <view>
        <view class="section-eyebrow">装备准备</view>
        <view class="section-title">装备概览</view>
      </view>
      <view class="section-link" bindtap="goGears">查看装备</view>
    </view>

    <view wx:if="{{!isLoggedIn}}" class="guest-inline">
      <view>
        <view class="guest-title">可以先浏览装备图鉴</view>
        <view class="guest-desc">登录后再管理自己的装备、重量和估值。</view>
      </view>
      <button bindtap="showLoginForGearSummary">去登录</button>
    </view>

    <view wx:if="{{gearError}}" class="state-card error">
      <view>{{gearError}}</view>
      <button bindtap="loadGearSummary">重试</button>
    </view>
    <block wx:else>
      <view wx:if="{{gearLoading}}" class="state-card"
        >正在加载装备状态...</view
      >
      <view wx:else class="stat-grid">
        <block wx:for="{{gearStatCards}}" wx:key="label">
          <view class="stat-card">
            <view class="stat-value">{{item.value}}</view>
            <view class="stat-label">{{item.label}}</view>
            <view class="stat-hint">{{item.hint}}</view>
          </view>
        </block>
      </view>

      <view wx:if="{{!gearLoading && recentGears.length}}" class="recent-list">
        <block wx:for="{{recentGears}}" wx:key="id">
          <view class="recent-item">
            <view>
              <view class="recent-name">{{item.name}}</view>
              <view class="recent-meta">{{item.brandModelText}}</view>
            </view>
            <view class="recent-weight">{{item.weightText}}</view>
          </view>
        </block>
      </view>
      <view wx:elif="{{!gearLoading && isLoggedIn}}" class="empty-inline">
        还没有装备记录，先添加第一件户外装备吧。
      </view>
    </block>
  </view>

  <view class="section-card">
    <view class="section-header">
      <view>
        <view class="section-eyebrow">技能复习</view>
        <view class="section-title">户外技能精选</view>
      </view>
      <view class="section-link" bindtap="goSkills">全部技能</view>
    </view>

    <view wx:if="{{skillError}}" class="state-card error">
      <view>{{skillError}}</view>
      <button bindtap="loadFeaturedSkills">重试</button>
    </view>
    <block wx:else>
      <view wx:if="{{skillLoading}}" class="state-card"
        >正在加载户外技能...</view
      >
      <view wx:elif="{{featuredSkills.length}}" class="skill-list">
        <block wx:for="{{featuredSkills}}" wx:key="id">
          <view
            class="skill-card"
            data-id="{{item.id}}"
            bindtap="goSkillDetail"
          >
            <view class="skill-tags">
              <text class="skill-tag">{{item.categoryText}}</text>
              <text class="skill-tag {{item.difficultyTone}}"
                >{{item.difficultyText}}</text
              >
            </view>
            <view class="skill-title">{{item.title}}</view>
            <view class="skill-summary">{{item.summary}}</view>
          </view>
        </block>
      </view>
      <view wx:else class="empty-inline">技能内容准备中。</view>
    </block>
  </view>

  <view class="section-card checklist-card">
    <view class="section-eyebrow">出发前</view>
    <view class="section-title">出发前检查</view>
    <block wx:for="{{checklistItems}}" wx:key="title">
      <view class="check-item">
        <view class="check-icon">{{item.icon}}</view>
        <view>
          <view class="check-title">{{item.title}}</view>
          <view class="check-desc">{{item.description}}</view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{wechatProfilePromptVisible}}" class="login-prompt-mask">
    <view class="login-prompt-card profile-import-card">
      <view class="login-prompt-close" bindtap="skipWechatProfileImport"
        >×</view
      >
      <view class="login-prompt-title">导入微信资料</view>
      <view class="login-prompt-message"
        >可以导入微信头像和昵称，跳过也不会影响使用。</view
      >
      <view wx:if="{{wechatProfileError}}" class="profile-import-error"
        >{{wechatProfileError}}</view
      >
      <view class="profile-import-form">
        <button
          class="profile-avatar-button"
          open-type="chooseAvatar"
          bindchooseavatar="onChooseWechatAvatar"
        >
          <image
            wx:if="{{wechatAvatarPath}}"
            class="profile-avatar-preview"
            src="{{wechatAvatarPath}}"
            mode="aspectFill"
          />
          <view wx:else class="profile-avatar-placeholder">头像</view>
        </button>
        <input
          class="profile-nickname-input"
          type="nickname"
          placeholder="微信昵称"
          value="{{wechatNickname}}"
          bindinput="onWechatNicknameInput"
        />
      </view>
      <view class="login-prompt-actions">
        <button
          class="secondary"
          loading="{{wechatProfileLoading}}"
          bindtap="skipWechatProfileImport"
        >
          跳过
        </button>
        <button
          wx:if="{{wechatProfilePromptCanRetry}}"
          class="primary"
          loading="{{wechatProfileLoading}}"
          bindtap="retryWechatAvatarUpload"
        >
          重试保存
        </button>
        <button
          wx:else
          class="primary"
          loading="{{wechatProfileLoading}}"
          bindtap="importWechatProfile"
        >
          导入资料
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{loginPrompt.visible}}" class="login-prompt-mask">
    <view class="login-prompt-card">
      <view class="login-prompt-close" bindtap="loginPromptClose">×</view>
      <view class="login-prompt-title">{{loginPrompt.title}}</view>
      <view class="login-prompt-message">{{loginPrompt.message}}</view>
      <view class="login-prompt-actions">
        <button class="secondary" bindtap="loginPromptClose">暂不登录</button>
        <button class="primary" bindtap="loginPromptGoLogin">去登录</button>
      </view>
    </view>
  </view>
</view>

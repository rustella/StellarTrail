.detail-page {
  min-height: 100vh;
  padding: 28rpx;
  background: var(--page-bg);
  box-sizing: border-box;
}

.plan-header,
.state-card,
.section,
.row-card,
.editor-card,
.weight-card {
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.plan-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
}

.plan-title,
.section-title,
.row-title,
.weight-value {
  color: var(--text-color);
  font-weight: 900;
}

.plan-title {
  font-size: 38rpx;
}

.plan-header-actions {
  display: flex;
  flex: 0 0 auto;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
}

.row-title {
  font-size: 28rpx;
}

.plan-meta,
.row-meta,
.weight-label,
.label {
  color: var(--muted-color);
  font-size: 24rpx;
  line-height: 1.5;
}

button {
  margin: 0;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.plan-header button,
.section-head button,
.editor-card button {
  padding: 0 24rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  line-height: 68rpx;
}

.plan-header .danger-action {
  color: #dc2626;
  background: rgba(220, 38, 38, 0.1);
}

.tabs {
  margin-top: 22rpx;
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  min-width: 100%;
}

.tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: var(--muted-color);
  background: var(--control-bg);
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
  box-sizing: border-box;
}

.tab.active {
  color: var(--brand-text-color);
  background: var(--brand-color);
}

.section-add-button {
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 40rpx;
  line-height: 60rpx;
  text-align: center;
}

.section-add-button::after,
.section-sheet-option::after,
.import-list-option::after,
.my-gear-import-option::after,
.load-sheet-more::after,
.sheet-primary-button::after,
.sheet-secondary-button::after,
.shared-gear-filter-chip::after,
.shared-gear-action::after,
.small-action::after,
.role-option::after {
  border: 0;
}

.section,
.state-card {
  margin-top: 22rpx;
  padding: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.itinerary-head-actions {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.itinerary-head-actions button {
  margin: 0;
  white-space: nowrap;
}

.itinerary-day-switcher {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 10rpx;
  border-radius: var(--card-inner-radius);
  background: var(--control-bg);
}

.itinerary-day-switch-button {
  flex: 0 0 64rpx;
  width: 64rpx;
  min-width: 64rpx;
  height: 58rpx;
  padding: 0;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 38rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.itinerary-day-switch-button.disabled {
  color: var(--muted-color);
  background: var(--surface-color);
  opacity: 0.56;
}

.itinerary-day-switch-button::after {
  border: 0;
}

.row-card,
.editor-card,
.weight-card {
  margin-top: 18rpx;
  padding: 22rpx;
  box-shadow: none;
}

.member-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.member-card-actions {
  display: flex;
  flex: 0 0 auto;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.owner-badge {
  display: inline-flex;
  margin-top: 8rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.2;
}

.member-carry-summary {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--soft-border-color);
}

.carry-breakdown {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 4rpx;
  color: var(--muted-color);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.25;
}

.member-carry-breakdown {
  flex: 1 1 190rpx;
}

.carry-total {
  justify-self: end;
  min-width: 132rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.member-carry-total {
  flex: 0 0 auto;
}

.small-action {
  flex: 0 0 auto;
  min-width: 96rpx;
  padding: 0 18rpx;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 24rpx;
  line-height: 58rpx;
}

.member-delete-button {
  line-height: 58rpx;
}

.personal-gear-action-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.personal-gear-section-head .section-add-button {
  margin: 0;
  padding: 0;
  line-height: 60rpx;
}

.personal-gear-add-button {
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.1);
}

.personal-gear-action-sheet .sheet-action-card {
  margin-top: 24rpx;
}

.personal-gear-action-copy {
  flex: 1 1 auto;
  min-width: 0;
}

.action-hint {
  margin-top: 6rpx;
  color: var(--muted-color);
  font-size: 23rpx;
  line-height: 1.45;
}

.personal-gear-actions {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.personal-gear-actions button {
  min-width: 174rpx;
  margin: 0;
  padding: 0 20rpx;
  white-space: nowrap;
}

.personal-gear-actions .secondary-action {
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
}

.shared-gear-action-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.weight-card {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.weight-value {
  font-size: 30rpx;
}

input,
textarea,
.picker-value {
  width: 100%;
  margin-top: 14rpx;
  padding: 0 20rpx;
  border-radius: var(--card-inner-radius);
  color: var(--text-color);
  background: var(--control-bg);
  font-size: 26rpx;
  box-sizing: border-box;
}

input,
.picker-value {
  min-height: 72rpx;
  line-height: 72rpx;
}

textarea {
  min-height: 142rpx;
  padding-top: 18rpx;
  line-height: 1.45;
}

.editor-card button,
.row-card button {
  margin-top: 16rpx;
}

.member-card-head .small-action {
  margin-top: 0;
}

.itinerary-workbench {
  margin-top: 18rpx;
}

.itinerary-day-card {
  overflow: hidden;
  padding: 0;
}

.itinerary-day-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx;
}

.itinerary-day-main,
.route-segment-main {
  flex: 1 1 auto;
  min-width: 0;
}

.itinerary-day-title-row {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 12rpx;
}

.itinerary-day-title,
.route-segment-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.itinerary-day-pager {
  flex: 1 1 auto;
  min-width: 0;
  padding: 0 12rpx;
  border-radius: 999rpx;
  color: var(--heading-muted-color);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.itinerary-day-meta {
  margin-top: 6rpx;
  font-weight: 700;
}

.itinerary-day-info-action {
  display: inline-flex;
  width: auto;
  min-width: 132rpx;
  height: 48rpx;
  margin: 12rpx 0 0 !important;
  padding: 0 18rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 48rpx;
  white-space: nowrap;
}

.itinerary-day-info-action::after {
  border: 0;
}

.itinerary-day-actions {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.itinerary-day-actions .delete-inline-button {
  min-width: 104rpx;
  margin-top: 0 !important;
}

.itinerary-swipe-hint {
  margin-top: 12rpx;
  color: var(--muted-color);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.4;
  text-align: center;
}

.route-estimate-eyebrow {
  color: var(--muted-color);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.route-estimate-title {
  margin-top: 6rpx;
  color: var(--text-color);
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
}

.route-estimate-desc {
  margin-top: 6rpx;
  color: var(--muted-color);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
}

.route-estimate-current {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: var(--card-inner-radius);
  background: var(--control-bg);
}

.delete-inline-button {
  flex: 0 0 auto;
  min-width: 88rpx;
  margin-top: 0 !important;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 52rpx;
  white-space: nowrap;
}

.edit-inline-button {
  flex: 0 0 auto;
  min-width: 88rpx;
  margin-top: 0 !important;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 52rpx;
  white-space: nowrap;
}

.delete-inline-button::after {
  border: 0;
}

.edit-inline-button::after {
  border: 0;
}

.itinerary-day-body {
  padding: 0 22rpx 22rpx;
  border-top: 1rpx solid var(--soft-border-color);
}

.route-empty {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--card-inner-radius);
  color: var(--muted-color);
  background: var(--control-bg);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
}

.route-segment-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: var(--card-inner-radius);
  background: var(--control-bg);
}

.route-segment-actions {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.route-segment-title {
  color: var(--text-color);
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
}

.route-segment-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.route-segment-chip {
  display: inline-flex;
  min-height: 38rpx;
  padding: 0 12rpx;
  align-items: center;
  border-radius: 999rpx;
  color: var(--heading-muted-color);
  background: var(--surface-color);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 38rpx;
  white-space: nowrap;
}

.route-segment-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}

.route-segment-estimate {
  margin-top: 8rpx;
  color: var(--muted-color);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}

.route-segment-altitude {
  color: var(--brand-soft-text);
}

.route-editor-card {
  margin-top: 18rpx;
}

.route-editor-trigger {
  width: 100%;
  margin-top: 14rpx !important;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  line-height: 66rpx;
}

.route-editor-trigger::after {
  border: 0;
}

.route-editor-section {
  margin-top: 14rpx;
  padding: 16rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: var(--card-inner-radius);
  background: var(--surface-color);
}

.route-editor-section-title {
  color: var(--muted-color);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.3;
}

.route-editor-grid {
  display: grid;
  gap: 12rpx;
  margin-top: 12rpx;
}

.route-editor-card input,
.route-editor-card .route-metric-control {
  background: var(--control-bg);
}

.route-editor-card button {
  line-height: 64rpx;
}

.route-editor-sheet {
  max-height: 88vh;
}

.route-editor-scroll {
  max-height: 72vh;
  margin-top: 6rpx;
}

.orphan-route-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx dashed var(--border-color);
  border-radius: var(--card-radius);
  background: var(--control-bg);
}

.orphan-route-card > .label {
  color: var(--muted-color);
  font-size: 23rpx;
  font-weight: 900;
}

.food-day-switcher {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 10rpx;
  border-radius: var(--card-inner-radius);
  background: var(--control-bg);
}

.food-day-pager {
  flex: 1 1 auto;
  min-width: 0;
  color: var(--heading-muted-color);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-workbench,
.food-supply-section {
  margin-top: 18rpx;
}

.food-day-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: var(--card-inner-radius);
  background: var(--brand-soft-bg);
}

.food-day-title {
  color: var(--brand-soft-text);
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
}

.food-meal-card {
  margin-top: 16rpx;
  padding: 20rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: var(--card-inner-radius);
  background: var(--surface-color);
}

.food-meal-card.skipped {
  border-style: dashed;
  background: var(--control-bg);
  opacity: 0.82;
}

.food-meal-head,
.food-item-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.food-meal-main,
.food-item-main {
  flex: 1 1 auto;
  min-width: 0;
}

.food-meal-title-row {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 10rpx;
}

.food-meal-title,
.food-item-title {
  overflow: hidden;
  color: var(--text-color);
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-meal-type {
  flex: 0 0 auto;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.2;
}

.food-meal-dish {
  margin-top: 8rpx;
  color: var(--heading-muted-color);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.3;
}

.food-meal-actions,
.food-row-actions {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.food-item-list {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--soft-border-color);
}

.food-empty {
  padding: 18rpx 20rpx;
  border-radius: var(--card-inner-radius);
  color: var(--muted-color);
  background: var(--control-bg);
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.4;
}

.food-item-row {
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: var(--card-inner-radius);
  background: var(--control-bg);
}

.food-supply-row {
  border: 1rpx solid var(--soft-border-color);
}

.food-add-button {
  width: 100%;
  margin-top: 14rpx !important;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  line-height: 66rpx;
}

.food-add-button::after {
  border: 0;
}

.goal-add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  min-width: 68rpx;
  height: 68rpx;
  margin-top: 18rpx !important;
  margin-right: auto !important;
  margin-left: auto !important;
  padding: 0;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 36rpx;
  line-height: 68rpx;
}

.goal-add-button::after {
  border: 0;
}

.goal-row-card {
  position: relative;
  padding-right: 92rpx;
}

.goal-delete-button {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 52rpx;
  min-width: 52rpx;
  height: 52rpx;
  padding: 0;
  color: #dc2626;
  background: var(--status-danger-bg);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.goal-delete-button::after {
  border: 0;
}

.goal-editor-card {
  padding: 16rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: var(--card-inner-radius);
  background: var(--control-bg);
}

.goal-editor-card textarea {
  min-height: 220rpx;
  background: var(--surface-color);
}

.section-subtitle {
  color: var(--muted-color);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
}

.food-editor-sheet {
  max-height: 88vh;
  overflow-y: auto;
}

.food-editor-section {
  margin-top: 14rpx;
  padding: 16rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: var(--card-inner-radius);
  background: var(--control-bg);
}

.food-editor-section input,
.food-editor-section textarea,
.food-editor-section .picker-value {
  background: var(--surface-color);
}

.food-editor-two-col {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.food-editor-full-field {
  grid-column: 1 / -1;
}

.budget-food-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid var(--soft-border-color);
  border-radius: var(--card-inner-radius);
  background: var(--brand-soft-bg);
}

.budget-source-kicker {
  color: var(--brand-soft-text);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.2;
}

.budget-source-title {
  margin-top: 6rpx;
  color: var(--text-color);
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
}

.budget-source-amount {
  flex: 0 0 auto;
  color: var(--brand-soft-text);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.budget-add-button {
  width: 100%;
  margin-top: 18rpx !important;
  color: var(--brand-soft-text);
  background: var(--brand-soft-bg);
  font-size: 27rpx;

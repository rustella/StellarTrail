          placeholder="无或简要说明"
        />

        <view class="field-label">过敏史</view>
        <textarea
          value="{{memberEditorForm.allergyHistory}}"
          data-field="allergyHistory"
          bindinput="onMemberEditorInput"
          placeholder="无或简要说明"
        />

        <view class="field-label">过敏 / 伤病处理方法</view>
        <textarea
          value="{{memberEditorForm.medicalResponseNote}}"
          data-field="medicalResponseNote"
          bindinput="onMemberEditorInput"
          placeholder="例如：随身药、禁忌或处置方式"
        />

        <view class="field-label">饮食习惯</view>
        <input
          value="{{memberEditorForm.dietPreference}}"
          data-field="dietPreference"
          bindinput="onMemberEditorInput"
          placeholder="例如：清真 / 素食 / 不吃牛羊肉"
        />

        <view class="field-label">保险单号</view>
        <input
          value="{{memberEditorForm.insurancePolicyNo}}"
          data-field="insurancePolicyNo"
          bindinput="onMemberEditorInput"
          placeholder="户外保险单号"
        />

        <view class="field-label">保险公司电话</view>
        <input
          value="{{memberEditorForm.insuranceCompanyPhone}}"
          data-field="insuranceCompanyPhone"
          bindinput="onMemberEditorInput"
          placeholder="保险报案电话"
        />

        <view class="field-label">户外经历 / 经验</view>
        <textarea
          value="{{memberEditorForm.experienceNote}}"
          data-field="experienceNote"
          bindinput="onMemberEditorInput"
          placeholder="例如：四姑娘山三峰，贡嘎环线等"
        />

        <view class="field-label">角色分工</view>
        <view class="role-option-row">
          <block wx:for="{{memberRoleOptions}}" wx:key="label">
            <button
              class="role-option {{item.selected ? 'selected' : ''}}"
              data-label="{{item.label}}"
              bindtap="toggleMemberRoleOption"
            >
              {{item.label}}
            </button>
          </block>
        </view>
        <input
          value="{{memberEditorForm.roleLabel}}"
          data-field="roleLabel"
          bindinput="onMemberEditorInput"
          placeholder="选择常见分工或自定义"
        />

        <button
          class="sheet-primary-button"
          loading="{{mutating}}"
          bindtap="saveMemberProfile"
        >
          保存成员信息
        </button>
      </scroll-view>
    </view>
  </view>

  <view
    wx:if="{{inviteVisible}}"
    class="invite-mask"
    bindtap="closeInvitePanel"
  >
    <view class="invite-panel" catchtap="stopTap">
      <view class="invite-title">邀请队员加入</view>
      <view class="invite-desc">邀请说明已复制，也可以直接分享到微信群。</view>
      <view class="invite-token">{{inviteToken}}</view>
      <view class="invite-actions">
        <button open-type="share" class="primary">分享微信群</button>
        <button class="secondary" bindtap="copyInviteToken">复制口令</button>
      </view>
      <button class="ghost" bindtap="closeInvitePanel">完成</button>
    </view>
  </view>

  <view wx:if="{{loginPrompt.visible}}" class="login-prompt-mask">
    <view class="login-prompt-card">
      <view class="login-prompt-close" bindtap="loginPromptClose">×</view>
      <view class="login-prompt-title">{{loginPrompt.title}}</view>
      <view class="login-prompt-message">{{loginPrompt.message}}</view>
      <view class="login-prompt-actions">
        <button class="secondary" bindtap="loginPromptClose">先不登录</button>
        <button class="primary" bindtap="loginPromptGoLogin">去登录</button>
      </view>
    </view>
  </view>
</view>

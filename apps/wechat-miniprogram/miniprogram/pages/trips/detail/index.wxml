<view class="detail-page {{themeClass}}">
  <view wx:if="{{offlineNotice}}" class="offline-notice"
    >{{offlineNotice}}</view
  >
  <view wx:if="{{error}}" class="state-card error">{{error}}</view>
  <view wx:elif="{{loading}}" class="state-card">正在加载组队计划书...</view>

  <block wx:elif="{{detail}}">
    <view class="plan-header">
      <view>
        <view class="plan-title">{{detail.plan.name}}</view>
        <view class="plan-meta">{{planMetaText}}</view>
      </view>
      <view class="plan-header-actions">
        <button bindtap="goEditPlan">编辑</button>
        <button
          wx:if="{{canDeletePlan}}"
          class="danger-action"
          bindtap="confirmDeletePlan"
          loading="{{mutating}}"
        >
          删除
        </button>
      </view>
    </view>

    <scroll-view
      class="tabs"
      scroll-x
      enable-flex
      scroll-with-animation
      scroll-into-view="{{activeSectionTabId}}"
    >
      <view class="tab-row">
        <block wx:for="{{sectionTabs}}" wx:key="key">
          <view
            id="{{item.id}}"
            class="tab {{selectedSection === item.key ? 'active' : ''}}"
            data-key="{{item.key}}"
            bindtap="switchSection"
          >
            {{item.label}}
          </view>
        </block>
        <button
          class="section-add-button"
          aria-label="添加计划项"
          bindtap="openSectionSheet"
        >
          +
        </button>
      </view>
    </scroll-view>

    <view wx:if="{{selectedSection === 'members'}}" class="section">
      <view class="section-head">
        <view class="section-title">成员信息</view>
        <button bindtap="createInvite" loading="{{mutating}}">邀请</button>
      </view>
      <block wx:for="{{members}}" wx:key="id">
        <view class="row-card member-card">
          <view class="member-card-head">
            <view>
              <view class="row-title">{{item.displayName}}</view>
              <view wx:if="{{item.is_owner}}" class="owner-badge">队长</view>
            </view>
            <view class="member-card-actions">
              <button
                wx:if="{{item.canEdit}}"
                class="small-action"
                data-id="{{item.id}}"
                bindtap="openMemberEditor"
                disabled="{{mutating}}"
              >
                编辑
              </button>
              <button
                wx:if="{{item.canDelete}}"
                class="delete-inline-button member-delete-button"
                data-id="{{item.id}}"
                bindtap="confirmRemoveMember"
                disabled="{{mutating}}"
              >
                删除
              </button>
            </view>
          </view>
          <view class="row-meta">{{item.roleText}} · {{item.contactText}}</view>
          <view class="row-meta">{{item.profileSummaryText}}</view>
          <view class="row-meta">{{item.healthText}}</view>
          <view wx:if="{{item.hasCarrySummary}}" class="member-carry-summary">
            <view class="carry-breakdown member-carry-breakdown">
              <text>公共 {{item.sharedWeightText}}</text>
              <text>个人 {{item.personalWeightText}}</text>
              <text wx:if="{{item.showFoodWeight}}"
                >食材 {{item.foodWeightText}}</text
              >
            </view>
            <view class="carry-total member-carry-total">
              {{item.totalWeightText}}
            </view>
          </view>
        </view>
      </block>
    </view>

    <view wx:elif="{{selectedSection === 'personal_gear'}}" class="section">
      <view class="section-head personal-gear-section-head">
        <view class="section-title">个人装备</view>
        <button
          class="section-add-button personal-gear-add-button"
          aria-label="添加个人装备"
          bindtap="openPersonalGearActionSheet"
        >
          +
        </button>
      </view>
      <view wx:if="{{myGearView}}" class="weight-card">
        <view>
          <view class="weight-value">{{myGearView.all_weight_g}} g</view>
          <view class="weight-label">所有装备重量</view>
        </view>
        <view>
          <view class="weight-value">{{myGearView.actual_weight_g}} g</view>
          <view class="weight-label">实际装备重量</view>
        </view>
      </view>
      <block wx:for="{{myGearView.items}}" wx:key="id">
        <view class="gear-row">
          <view class="gear-row-head">
            <view class="row-title">{{item.name}}</view>
            <button
              wx:if="{{item.source === 'personal' && sharedGearEnabled}}"
              class="small-action"
              data-id="{{item.id}}"
              catchtap="confirmMovePersonalGearToShared"
              loading="{{mutating}}"
            >
              移到公共
            </button>
          </view>
          <view class="row-meta"
            >{{item.category_label}} · {{item.planned_quantity}} 件</view
          >
          <view class="labels">
            <block wx:for="{{item.labels}}" wx:key="*this">
              <text>{{item}}</text>
            </block>
          </view>
        </view>
      </block>
    </view>

    <view wx:elif="{{selectedSection === 'shared_gear'}}" class="section">
      <view class="section-title">公共装备</view>
      <view class="editor-card shared-gear-action-card">
        <view class="personal-gear-action-copy">
          <view class="label">公共装备需求</view>
          <view class="action-hint"
            >先列出炉头、煮锅等公共装备需求，再为每项导入或填写具体装备。</view
          >
        </view>
        <view class="personal-gear-actions">
          <button bindtap="openSharedGearForm">新增需求项</button>
        </view>
      </view>
      <scroll-view
        wx:if="{{sharedGearCategoryOptions.length > 1}}"
        class="shared-gear-filter"
        scroll-x
        enable-flex
      >
        <view class="shared-gear-filter-row">
          <button
            wx:for="{{sharedGearCategoryOptions}}"
            wx:key="value"
            class="shared-gear-filter-chip {{item.selected ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="switchSharedGearCategory"
          >
            <text class="shared-gear-filter-label">{{item.label}}</text>
            <text class="shared-gear-filter-count">{{item.count}}</text>
          </button>
        </view>
      </scroll-view>
      <block wx:for="{{sharedGearRows}}" wx:key="id">
        <view
          class="row-card shared-gear-row {{item.hasConcreteGear ? 'filled' : 'empty'}}"
        >
          <view class="shared-gear-head">
            <view class="shared-gear-main">
              <view class="row-title">{{item.slotName}}</view>
              <view class="row-meta"
                >{{item.slotGroup}} · {{item.categoryLabel}} · 需求
                {{item.plannedQuantityText}}</view
              >
            </view>
            <view class="shared-gear-actions">
              <button
                class="shared-gear-action"
                data-id="{{item.id}}"
                bindtap="openSharedSlotSheet"
              >
                {{item.actionText}}
              </button>
              <button
                class="shared-gear-action shared-gear-delete"
                data-id="{{item.id}}"
                catchtap="confirmDeleteSharedGear"
                loading="{{mutating}}"
              >
                删除
              </button>
            </view>
          </view>
          <view wx:if="{{item.hasConcreteGear}}" class="row-meta">
            具体装备：{{item.concreteName}} · {{item.weightText}}
          </view>
          <view wx:else class="row-meta shared-gear-empty-text">
            待填写具体装备，不计入背负重量
          </view>
          <view class="row-meta"
            >负责人（背负/保管）：{{item.responsibleText}}</view
          >
          <view class="row-meta">
            归属：{{item.sourceText}} · 来源：{{item.createdByText}}
          </view>
        </view>
      </block>
    </view>

    <view wx:elif="{{selectedSection === 'itinerary'}}" class="section">
      <view class="section-head">
        <view class="section-title">行程安排</view>
        <view class="itinerary-head-actions">
          <button class="small-action" bindtap="openRouteEstimateSheet">
            设置
          </button>
          <button bindtap="addItineraryDay" loading="{{mutating}}">
            新增一天
          </button>
        </view>
      </view>
      <view wx:if="{{activeItineraryDay}}" class="itinerary-day-switcher">
        <button
          class="itinerary-day-switch-button {{canSwitchPrevDay ? '' : 'disabled'}}"
          disabled="{{!canSwitchPrevDay}}"
          catchtap="switchPrevItineraryDay"
        >
          ‹
        </button>
        <view
          class="itinerary-day-pager"
          bindtouchstart="onItineraryTouchStart"
          bindtouchend="onItineraryTouchEnd"
        >
          {{activeItineraryDay.title}} · {{itineraryDayPagerText}}
        </view>
        <button
          class="itinerary-day-switch-button {{canSwitchNextDay ? '' : 'disabled'}}"
          disabled="{{!canSwitchNextDay}}"
          catchtap="switchNextItineraryDay"
        >
          ›
        </button>
      </view>
      <view wx:if="{{activeItineraryDay}}" class="itinerary-workbench">
        <view class="row-card itinerary-day-card">
          <view class="itinerary-day-head">
            <view
              class="itinerary-day-main"
              bindtouchstart="onItineraryTouchStart"
              bindtouchend="onItineraryTouchEnd"
            >
              <view class="itinerary-day-title-row">
                <view class="row-title itinerary-day-title"
                  >{{activeItineraryDay.title}}</view
                >
              </view>
              <view class="row-meta itinerary-day-meta"
                >{{activeItineraryDay.estimateText}} ·
                {{activeItineraryDay.dateText}}</view
              >
              <button
                class="itinerary-day-info-action"
                data-id="{{activeItineraryDay.id}}"
                catchtap="openDayInfoEditor"
              >
                编辑日信息
              </button>
            </view>
            <view class="itinerary-day-actions">
              <button
                class="delete-inline-button"
                data-id="{{activeItineraryDay.id}}"
                catchtap="confirmDeleteItineraryDay"
                loading="{{mutating}}"
              >
                删除
              </button>
            </view>
          </view>
          <view class="itinerary-day-body">
            <view
              class="itinerary-route-list"
              bindtouchstart="onItineraryTouchStart"
              bindtouchend="onItineraryTouchEnd"
            >
              <view
                wx:if="{{!activeItineraryDay.routeSegments.length}}"
                class="route-empty"
                >暂无路段</view
              >
              <block
                wx:for="{{activeItineraryDay.routeSegments}}"
                wx:for-item="segment"
                wx:key="id"
              >
                <view class="route-segment-row">
                  <view class="route-segment-main">
                    <view class="row-title route-segment-title"
                      >{{segment.name}}</view
                    >
                    <view class="route-segment-metrics">
                      <text
                        wx:for="{{segment.metricChips}}"
                        wx:for-item="chip"
                        wx:key="*this"
                        class="route-segment-chip"
                        >{{chip}}</text
                      >
                    </view>
                    <view
                      wx:if="{{segment.detailText}}"
                      class="row-meta route-segment-meta"
                      >{{segment.detailText}}</view
                    >
                    <view class="row-meta route-segment-estimate"
                      >{{segment.estimateText}}</view
                    >
                    <view
                      wx:if="{{segment.altitudeText}}"
                      class="row-meta route-segment-altitude"
                      >{{segment.altitudeText}}</view
                    >
                    <view
                      wx:if="{{segment.safetyText}}"
                      class="row-meta route-segment-meta"
                      >{{segment.safetyText}}</view
                    >
                  </view>
                  <view class="route-segment-actions">
                    <button
                      class="edit-inline-button"
                      data-id="{{segment.id}}"
                      catchtap="openEditRouteEditor"
                      loading="{{mutating}}"
                    >
                      编辑
                    </button>
                    <button
                      class="delete-inline-button"
                      data-id="{{segment.id}}"
                      catchtap="confirmDeleteRouteSegment"
                      loading="{{mutating}}"
                    >
                      删除
                    </button>
                  </view>
                </view>
              </block>
            </view>
            <button class="route-editor-trigger" bindtap="openRouteEditor">
              + 添加路段
            </button>
          </view>
        </view>
        <view wx:if="{{itineraryDayCount > 1}}" class="itinerary-swipe-hint">
          点箭头或左右滑动切换行程日
        </view>
      </view>
      <view wx:if="{{orphanRouteSegments.length}}" class="orphan-route-card">
        <view class="label">未分配路段</view>
        <block
          wx:for="{{orphanRouteSegments}}"
          wx:for-item="segment"
          wx:key="id"
        >
          <view class="route-segment-row">
            <view class="route-segment-main">
              <view class="row-title route-segment-title"
                >{{segment.name}}</view
              >
              <view class="route-segment-metrics">
                <text
                  wx:for="{{segment.metricChips}}"
                  wx:for-item="chip"
                  wx:key="*this"
                  class="route-segment-chip"
                  >{{chip}}</text
                >
              </view>
              <view
                wx:if="{{segment.detailText}}"
                class="row-meta route-segment-meta"
                >{{segment.detailText}}</view
              >
              <view class="row-meta route-segment-estimate"
                >{{segment.estimateText}}</view
              >
              <view
                wx:if="{{segment.altitudeText}}"
                class="row-meta route-segment-altitude"
                >{{segment.altitudeText}}</view
              >
            </view>
            <view class="route-segment-actions">
              <button
                class="edit-inline-button"
                data-id="{{segment.id}}"
                catchtap="openEditRouteEditor"
                loading="{{mutating}}"
              >
                编辑
              </button>
              <button
                class="delete-inline-button"
                data-id="{{segment.id}}"
                catchtap="confirmDeleteRouteSegment"
                loading="{{mutating}}"
              >
                删除
              </button>
            </view>
          </view>
        </block>
      </view>
      <view wx:if="{{!itineraryDays.length}}" class="state-card">
        先新增一天，再添加这一天的路段。
      </view>
    </view>

    <view wx:elif="{{selectedSection === 'food_plan'}}" class="section">
      <view class="section-head">
        <view>
          <view class="section-title">食品计划</view>
          <view class="row-meta">食材重量进入背负统计，费用进入财务预算。</view>
        </view>
        <button class="small-action" bindtap="openFoodSupplyEditor">
          公共食材
        </button>
      </view>
      <view wx:if="{{foodBlocked}}" class="state-card"
        >先添加行程日后才能编辑食品计划。</view
      >
      <block wx:else>
        <view wx:if="{{activeFoodDay}}" class="food-day-switcher">
          <button
            class="itinerary-day-switch-button {{canSwitchPrevFoodDay ? '' : 'disabled'}}"
            disabled="{{!canSwitchPrevFoodDay}}"
            catchtap="switchPrevFoodDay"
          >
            ‹
          </button>
          <view class="food-day-pager">
            {{activeFoodDay.title}} · {{foodDayPagerText}}
          </view>
          <button
            class="itinerary-day-switch-button {{canSwitchNextFoodDay ? '' : 'disabled'}}"
            disabled="{{!canSwitchNextFoodDay}}"
            catchtap="switchNextFoodDay"
          >
            ›
          </button>
        </view>
        <view wx:if="{{activeFoodDay}}" class="food-workbench">
          <view class="food-day-summary">
            <view>
              <view class="food-day-title">{{activeFoodDay.dateText}}</view>
              <view class="row-meta">{{activeFoodDay.summaryText}}</view>
            </view>
          </view>
          <block
            wx:for="{{activeFoodDay.meals}}"
            wx:for-item="meal"
            wx:key="id"
          >
            <view class="food-meal-card {{meal.skipped ? 'skipped' : ''}}">
              <view class="food-meal-head">
                <view class="food-meal-main">
                  <view class="food-meal-title-row">
                    <view class="row-title food-meal-title"
                      >{{meal.label}}</view
                    >
                    <view wx:if="{{meal.meal_type}}" class="food-meal-type">
                      {{meal.meal_type}}
                    </view>
                  </view>
                  <view class="food-meal-dish">{{meal.summaryText}}</view>
                  <view class="row-meta">
                    负责人：{{meal.responsibleText}} · {{meal.itemCountText}} ·
                    {{meal.weightText}}
                  </view>
                </view>
                <view class="food-meal-actions">
                  <button
                    class="edit-inline-button"
                    data-id="{{meal.id}}"
                    catchtap="openFoodMealEditor"
                    loading="{{mutating}}"
                  >
                    编辑
                  </button>
                  <button
                    class="{{meal.skipped ? 'edit-inline-button' : 'delete-inline-button'}}"
                    data-id="{{meal.id}}"
                    catchtap="toggleMealSkip"
                    loading="{{mutating}}"
                  >
                    {{meal.skipped ? '恢复' : '跳过'}}
                  </button>
                </view>
              </view>
              <view wx:if="{{!meal.skipped}}" class="food-item-list">
                <view wx:if="{{!meal.items.length}}" class="food-empty">
                  还没有食材，添加后会计入食材背负重量。
                </view>
                <block wx:for="{{meal.items}}" wx:for-item="food" wx:key="id">
                  <view class="food-item-row">
                    <view class="food-item-main">
                      <view class="food-item-title">{{food.name}}</view>
                      <view class="row-meta">
                        {{food.weightText}} · {{food.costText}} · 负责人
                        {{food.responsibleText}}
                      </view>
                      <view wx:if="{{food.notesText}}" class="row-meta">
                        {{food.notesText}}
                      </view>
                    </view>
                    <view class="food-row-actions">
                      <button
                        class="edit-inline-button"
                        data-meal-id="{{meal.id}}"
                        data-id="{{food.id}}"
                        catchtap="openFoodItemEditor"
                        loading="{{mutating}}"
                      >
                        编辑
                      </button>
                      <button
                        class="delete-inline-button"
                        data-meal-id="{{meal.id}}"
                        data-id="{{food.id}}"
                        catchtap="confirmDeleteFoodItem"
                        loading="{{mutating}}"
                      >
                        删除
                      </button>
                    </view>
                  </view>
                </block>
                <button
                  class="food-add-button"
                  data-meal-id="{{meal.id}}"
                  bindtap="openFoodItemEditor"
                >
                  + 添加食材
                </button>
              </view>
            </view>
          </block>
        </view>
        <view wx:if="{{foodSupplyRows.length}}" class="food-supply-section">
          <view class="section-subtitle">跨餐公共食材</view>
          <block wx:for="{{foodSupplyRows}}" wx:key="id">
            <view class="food-item-row food-supply-row">
              <view class="food-item-main">
                <view class="food-item-title">{{item.name}}</view>
                <view class="row-meta">
                  {{item.typeText}} · {{item.weightText}} · {{item.costText}} ·
                  负责人 {{item.responsibleText}}
                </view>
                <view wx:if="{{item.notesText}}" class="row-meta">
                  {{item.notesText}}
                </view>
              </view>
              <view class="food-row-actions">
                <button
                  class="edit-inline-button"
                  data-id="{{item.id}}"
                  catchtap="openFoodSupplyEditor"
                  loading="{{mutating}}"
                >
                  编辑
                </button>
                <button
                  class="delete-inline-button"
                  data-id="{{item.id}}"
                  catchtap="confirmDeleteFoodSupply"
                  loading="{{mutating}}"
                >
                  删除
                </button>
              </view>
            </view>
          </block>
        </view>
      </block>
    </view>

    <view wx:elif="{{selectedSection === 'medical_kit'}}" class="section">
      <view class="section-head medical-kit-head">
        <view>
          <view class="section-title">医药包</view>
          <view class="row-meta">公共急救和个人药品提醒集中管理。</view>
        </view>
        <button
          class="small-action medical-add-button"
          bindtap="openMedicalEditor"
        >
          新增物品
        </button>
      </view>
      <view wx:if="{{medicalSummary.hasItems}}" class="medical-summary">
        <view class="medical-summary-cell">
          <view class="medical-summary-value"
            >{{medicalSummary.itemCountText}}</view
          >
          <view class="medical-summary-label">条目</view>
        </view>
        <view class="medical-summary-cell">
          <view class="medical-summary-value"
            >{{medicalSummary.requiredText}}</view
          >
          <view class="medical-summary-label">计划</view>
        </view>
        <view class="medical-summary-cell">
          <view class="medical-summary-value"
            >{{medicalSummary.packedText}}</view
          >
          <view class="medical-summary-label">已带</view>
        </view>
        <view class="medical-summary-cell">
          <view class="medical-summary-value"
            >{{medicalSummary.shortageText}}</view
          >
          <view class="medical-summary-label">缺少</view>
        </view>
      </view>
      <block wx:for="{{medicalItems}}" wx:key="id">
        <view class="row-card medical-item-row">
          <view class="medical-item-main">
            <view class="medical-item-title-row">
              <view class="row-title">{{item.name}}</view>
              <text class="medical-scope-chip {{item.scopeClass}}">
                {{item.scopeText}}
              </text>
            </view>
            <view class="row-meta">{{item.typeText}}</view>
            <view class="medical-item-meta">
              <text>{{item.quantityText}}</text>
              <text wx:if="{{item.suggestedText}}">{{item.suggestedText}}</text>
            </view>
            <text class="medical-status-chip {{item.statusClass}}">
              {{item.statusText}}
            </text>
          </view>
          <view class="medical-item-actions">
            <button
              class="edit-inline-button"
              data-id="{{item.id}}"
              catchtap="openEditMedicalEditor"
              loading="{{mutating}}"
            >
              编辑
            </button>
            <button
              class="delete-inline-button"
              data-id="{{item.id}}"
              catchtap="confirmDeleteMedicalItem"
              loading="{{mutating}}"
            >
              删除
            </button>
          </view>
        </view>
      </block>
      <view wx:if="{{!medicalSummary.hasItems}}" class="medical-empty-state">
        <view class="medical-empty-title">还没有医药包物品</view>
        <view class="row-meta">先添加创可贴、弹力绷带、常用药等条目。</view>
        <button class="sheet-secondary-button" bindtap="openMedicalEditor">
          新增物品
        </button>
      </view>
    </view>

    <view wx:elif="{{selectedSection === 'safety_plan'}}" class="section">
      <view class="section-title">安全预案</view>
      <view class="editor-card">
        <input
          value="{{safetyRiskType}}"
          data-field="safetyRiskType"
          bindinput="onInput"
          placeholder="例如：下撤路线 / 失温 / 暴雨"
        />
        <textarea
          value="{{safetyPrevention}}"
          data-field="safetyPrevention"
          bindinput="onInput"
          placeholder="例如：提前确认下撤口、集合点和备用交通"
        />
        <textarea
          value="{{safetyResponse}}"
          data-field="safetyResponse"
          bindinput="onInput"
          placeholder="例如：从 XX 垭口下撤到 XX 村，联系 XX 车辆"
        />
        <picker
          value="{{safetyResponsibleIndex}}"
          range="{{members}}"
          range-key="displayName"
          bindchange="onSafetyResponsibleChange"
        >
          <view class="picker-value"
            >负责人：{{members[safetyResponsibleIndex].displayName ||
            '选择队员'}}</view
          >
        </picker>
        <button bindtap="addSafetyRisk" loading="{{mutating}}">添加预案</button>
      </view>
      <block wx:for="{{safetyRisks}}" wx:key="id">
        <view class="row-card">
          <view class="row-title">{{item.risk_type}}</view>
          <view class="row-meta"

          wx:for="{{optionalSections}}"
          wx:key="key"
          class="section-sheet-option {{item.enabled ? 'enabled' : ''}}"
          data-key="{{item.key}}"
          bindtap="selectOptionalSection"
        >
          <view class="section-sheet-option-copy">
            <view class="section-sheet-option-title">{{item.label}}</view>
            <view class="section-sheet-option-desc-row">
              <view class="section-sheet-option-desc"
                >{{item.enabled ? '已在导航中，点此可隐藏' :

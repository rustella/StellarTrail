<view class="gear-page {{themeClass}}">
  <view class="hero-card">
    <view>
      <view class="eyebrow">寻径星野装备库</view>
      <view class="hero-title"
        >{{isLoggedIn ? '我的户外装备' : '公告装备清单'}}</view
      >
      <view class="hero-subtitle"
        >{{isLoggedIn ? '按分类、状态和关键词快速管理装备，为下一次出行做准备。'
        : '免登录查看装备模板；登录后再同步个人装备。'}}</view
      >
    </view>
    <button class="primary-action" bindtap="goCreate">+ 添加</button>
  </view>

  <block wx:if="{{!isLoggedIn}}">
    <view class="guest-card">
      <view class="guest-icon">🎒</view>
      <view>
        <view class="guest-title">当前为游客模式</view>
        <view class="guest-desc"
          >你可以先浏览装备模板和公告清单。添加、编辑、归档和恢复个人装备前会提示登录。</view
        >
      </view>
      <button bindtap="goLogin">登录</button>
    </view>

    <view class="template-section">
      <view class="template-section-title">装备模板</view>
      <view class="template-section-desc"
        >公开清单可作为出发前检查参考，不需要登录。</view
      >
      <view wx:if="{{templateLoading}}" class="loading-card"
        >正在加载装备模板...</view
      >
      <view wx:elif="{{templateError}}" class="error-card">
        <view>{{templateError}}</view>
        <button bindtap="loadTemplates">重试</button>
      </view>
      <view wx:elif="{{!templates.length}}" class="empty-card">
        <view class="empty-title">装备模板准备中</view>
        <view class="empty-subtitle">稍后会展示公开装备清单。</view>
      </view>
      <block wx:else>
        <block wx:for="{{templates}}" wx:key="id">
          <view class="template-card">
            <view class="template-card-head">
              <view>
                <view class="template-title">{{item.title}}</view>
                <view class="template-meta"
                  >{{item.categoryCountText}} · {{item.itemCountText}}</view
                >
              </view>
              <button catchtap="useTemplate" data-id="{{item.id}}">
                保存到我的
              </button>
            </view>
            <view class="template-preview">
              <block
                wx:for="{{item.previewItems}}"
                wx:key="*this"
                wx:for-item="preview"
              >
                <text>{{preview}}</text>
              </block>
            </view>
            <view class="template-category-list">
              <block
                wx:for="{{item.categories}}"
                wx:key="id"
                wx:for-item="category"
              >
                <view class="template-category">
                  <view class="template-category-name">{{category.name}}</view>
                  <view class="template-category-items"
                    >{{category.itemText}}</view
                  >
                </view>
              </block>
            </view>
          </view>
        </block>
      </block>
    </view>
  </block>

  <block wx:else>
    <view class="tab-card">
      <block wx:for="{{tabOptions}}" wx:key="value">
        <view
          class="tab-item {{tab === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="switchTab"
        >
          {{item.label}}
        </view>
      </block>
    </view>

    <view class="stats-grid">
      <block wx:for="{{statCards}}" wx:key="label">
        <view class="stat-card">
          <view class="stat-value">{{item.value}}</view>
          <view class="stat-label">{{item.label}}</view>
          <view class="stat-hint">{{item.hint}}</view>
        </view>
      </block>
    </view>

    <view class="search-card">
      <input
        class="search-input"
        value="{{q}}"
        placeholder="搜索装备名、品牌、型号"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="submitSearch"
      />
      <button class="search-button" bindtap="submitSearch">搜索</button>
      <button wx:if="{{q}}" class="clear-button" bindtap="clearSearch">
        清除
      </button>
    </view>

    <scroll-view class="category-scroll" scroll-x enable-flex>
      <block wx:for="{{categories}}" wx:key="id">
        <view
          class="category-chip {{selectedCategory === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectCategory"
        >
          <text>{{item.label}}</text>
          <text class="chip-count">{{item.count}}</text>
        </view>
      </block>
    </scroll-view>

    <view class="filter-row">
      <picker
        value="{{selectedStatusIndex}}"
        range="{{statusLabels}}"
        bindchange="onStatusChange"
      >
        <view class="filter-pill">{{statusLabels[selectedStatusIndex]}}</view>
      </picker>
      <picker
        value="{{selectedSortIndex}}"
        range="{{sortLabels}}"
        bindchange="onSortChange"
      >
        <view class="filter-pill">{{sortLabels[selectedSortIndex]}}</view>
      </picker>
    </view>

    <view wx:if="{{error}}" class="error-card">
      <view>{{error}}</view>
      <button bindtap="refreshPage">重试</button>
    </view>

    <block wx:else>
      <view wx:if="{{loading}}" class="loading-card">正在加载装备库...</view>

      <view wx:elif="{{!gears.length}}" class="empty-card">
        <view class="empty-title">{{emptyText}}</view>
        <view class="empty-subtitle"
          >用移动端卡片记录重量、价格、存放位置和共享设置。</view
        >
        <button
          wx:if="{{tab === 'available'}}"
          class="primary-action wide"
          bindtap="goCreate"
        >
          添加第一件装备
        </button>
      </view>

      <view wx:else class="gear-list">
        <block wx:for="{{gears}}" wx:key="id">
          <view class="gear-card" data-id="{{item.id}}" bindtap="goDetail">
            <view class="card-topline">
              <view class="category-badge">{{item.categoryText}}</view>
              <view class="status-badge {{item.statusTone}}"
                >{{item.statusText}}</view
              >
            </view>
            <view class="gear-name">{{item.name}}</view>
            <view class="gear-meta">{{item.brandModelText}}</view>
            <view class="metrics-row">
              <view class="metric">
                <view class="metric-value">{{item.weightText}}</view>
                <view class="metric-label">重量</view>
              </view>
              <view class="metric">
                <view class="metric-value">{{item.priceText}}</view>
                <view class="metric-label">价格</view>
              </view>
              <view class="metric">
                <view class="metric-value">{{item.purchaseDateText}}</view>
                <view class="metric-label">购买日期</view>
              </view>
            </view>
            <view class="card-actions">
              <button catchtap="goEdit" data-id="{{item.id}}">编辑</button>
              <button
                wx:if="{{tab === 'available'}}"
                class="danger"
                catchtap="archiveItem"
                data-id="{{item.id}}"
              >
                移入历史
              </button>
              <button
                wx:else
                class="restore"
                catchtap="restoreItem"
                data-id="{{item.id}}"
              >
                恢复
              </button>
            </view>
          </view>
        </block>
      </view>

      <view wx:if="{{loadingMore}}" class="load-more">继续加载...</view>
      <view wx:elif="{{gears.length && !nextCursor}}" class="load-more muted"
        >没有更多装备了</view
      >
    </block>
  </block>

  <view wx:if="{{loginPrompt.visible}}" class="login-prompt-mask">
    <view class="login-prompt-card">
      <view class="login-prompt-close" bindtap="loginPromptClose">×</view>
      <view class="login-prompt-title">{{loginPrompt.title}}</view>
      <view class="login-prompt-message">{{loginPrompt.message}}</view>
      <view class="login-prompt-actions">
        <button class="secondary" bindtap="loginPromptClose">暂不登录</button>
        <button class="primary" bindtap="loginPromptGoLogin">去登录</button>
      </view>
    </view>
  </view>
</view>

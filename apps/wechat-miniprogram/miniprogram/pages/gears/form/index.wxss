.form-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 140rpx;
  background: var(--page-bg);
  box-sizing: border-box;
  color: var(--text-color);
}

.intro-card,
.form-card,
.error-card,
.state-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
  border: 1rpx solid var(--border-color);
  color: var(--text-color);
}

.intro-card {
  color: #0f172a;
  background: var(--hero-surface-gradient);
  border: 1rpx solid var(--hero-surface-border);
  border-radius: var(--hero-card-radius);
  box-shadow: var(--hero-surface-shadow);
}

.intro-title {
  font-size: 38rpx;
  font-weight: 800;
}

.intro-subtitle {
  margin-top: 10rpx;
  color: var(--muted-color);
  font-size: 26rpx;
  line-height: 1.55;
}

.section-title {
  margin-bottom: 18rpx;
  color: var(--text-color);
  font-size: 30rpx;
  font-weight: 800;
}

.field,
.picker-row,
.switch-row {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: var(--card-inner-radius);
  background: var(--control-bg);
}

.field-label {
  color: var(--heading-muted-color);
  font-size: 24rpx;
  font-weight: 700;
}

.field-label.required::after {
  content: " *";
  color: #dc2626;
}

.field-value {
  margin-top: 8rpx;
  color: var(--text-color);
  font-size: 28rpx;
  font-weight: 800;
}

.field-hint {
  margin-top: 8rpx;
  color: var(--muted-color);
  font-size: 22rpx;
  line-height: 1.45;
}

input,
textarea {
  width: 100%;
  margin-top: 12rpx;
  color: var(--text-color);
  font-size: 28rpx;
  line-height: 1.5;
}

textarea {
  min-height: 132rpx;
}

.two-column {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.field.compact {
  min-width: 0;
}

.picker-row,
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.chevron {
  color: var(--muted-color);
  font-size: 44rpx;
}

.error-card {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
  font-size: 26rpx;
}

.state-card {
  color: var(--muted-color);
  font-size: 26rpx;
  text-align: center;
}

.footer-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(15, 23, 42, 0.08);
}

.footer-actions button {
  flex: 1;
  margin: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 82rpx;
}

.footer-actions .secondary {
  color: var(--heading-muted-color);
  background: #e2e8f0;
}

.footer-actions .primary {
  color: var(--brand-text-color);
  background: var(--brand-color);
}

/* Dark theme overrides */
.form-page.theme-dark {
  background: var(--body-gradient);
  color: var(--text-color);
}

.form-page.theme-dark .intro-card {
  background: var(--hero-gradient);
  box-shadow: var(--shadow-card);
}

.form-page.theme-dark .form-card,
.form-page.theme-dark .error-card,
.form-page.theme-dark .state-card {
  border: 1rpx solid var(--border-color);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.form-page.theme-dark .section-title,
.form-page.theme-dark .field-value,
.form-page.theme-dark input,
.form-page.theme-dark textarea {
  color: var(--text-color);
}

.form-page.theme-dark .field-label {
  color: var(--heading-muted-color);
}

.form-page.theme-dark .field-hint,
.form-page.theme-dark .state-card,
.form-page.theme-dark .chevron {
  color: var(--muted-color);
}

.form-page.theme-dark .field,
.form-page.theme-dark .picker-row,
.form-page.theme-dark .switch-row {
  background: var(--control-bg);
}

.form-page.theme-dark .error-card {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
}

.form-page.theme-dark .footer-actions {
  background: var(--footer-bg);
  box-shadow: 0 -8rpx 28rpx rgba(3, 1, 12, 0.42);
}

.form-page.theme-dark .footer-actions .secondary {
  color: var(--soft-control-text);
  background: var(--soft-control-bg);
}

.form-page.theme-dark .footer-actions .primary {
  color: var(--brand-text-color);
  background: var(--brand-color);
}

.login-required-card {
  margin-top: 80rpx;
  text-align: center;
}

.login-required-title {
  color: var(--text-color);
  font-size: 32rpx;
  font-weight: 900;
}

.login-required-desc {
  margin-top: 12rpx;
  color: var(--muted-color);
  font-size: 26rpx;
  line-height: 1.55;
}

.login-required-card button {
  margin: 28rpx auto 0;
  padding: 0 42rpx;
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 27rpx;
  font-weight: 800;
  line-height: 76rpx;
}

.form-page.theme-dark .intro-card,
.form-page.theme-dark .intro-title {
  color: #ffffff;
}

.form-page.theme-dark .intro-subtitle {
  color: rgba(255, 255, 255, 0.82);
}

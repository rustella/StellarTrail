.form-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 140rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.intro-card,
.form-card,
.error-card,
.state-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.intro-card {
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e 0%, #115e59 100%);
}

.intro-title {
  font-size: 38rpx;
  font-weight: 800;
}

.intro-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  line-height: 1.55;
}

.section-title {
  margin-bottom: 18rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
}

.field,
.picker-row,
.switch-row {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.field-label {
  color: #475569;
  font-size: 24rpx;
  font-weight: 700;
}

.field-label.required::after {
  content: " *";
  color: #dc2626;
}

.field-value {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.field-hint {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.45;
}

input,
textarea {
  width: 100%;
  margin-top: 12rpx;
  color: #0f172a;
  font-size: 28rpx;
  line-height: 1.5;
}

textarea {
  min-height: 132rpx;
}

.two-column {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.field.compact {
  min-width: 0;
}

.picker-row,
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.chevron {
  color: #94a3b8;
  font-size: 44rpx;
}

.error-card {
  color: #b91c1c;
  background: #fff1f2;
  font-size: 26rpx;
}

.state-card {
  color: #64748b;
  font-size: 26rpx;
  text-align: center;
}

.footer-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(15, 23, 42, 0.08);
}

.footer-actions button {
  flex: 1;
  margin: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 82rpx;
}

.footer-actions .secondary {
  color: #475569;
  background: #e2e8f0;
}

.footer-actions .primary {
  color: #ffffff;
  background: #0f766e;
}

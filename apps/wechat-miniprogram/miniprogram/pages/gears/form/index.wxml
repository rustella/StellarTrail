<view class="form-page {{themeClass}}">
  <view wx:if="{{requiresLogin}}" class="state-card login-required-card">
    <view class="login-required-title"
      >登录后{{mode === 'edit' ? '编辑装备' : '添加装备'}}</view
    >
    <view class="login-required-desc"
      >添加或修改装备会保存到你的个人清单，请先登录。</view
    >
    <button bindtap="loginPromptGoLogin">去登录</button>
  </view>

  <block wx:else>
    <view wx:if="{{error}}" class="error-card">{{error}}</view>
    <view wx:if="{{loading}}" class="state-card">正在加载装备信息...</view>

    <view class="form-actions">
      <button class="secondary" bindtap="cancel">取消</button>
      <button class="primary" loading="{{submitting}}" bindtap="submitForm">
        {{mode === 'edit' ? '保存' : '添加'}}
      </button>
    </view>

    <view class="intro-card">
      <view class="intro-title"
        >{{mode === 'edit' ? '编辑装备信息' : '添加一件装备'}}</view
      >
      <view class="intro-subtitle"
        >先填写最关键的信息，重量、价格和存放位置之后也能随时补充。</view
      >
    </view>

    <view class="form-card">
      <view class="section-title">基本信息</view>
      <picker
        value="{{categoryIndex}}"
        range="{{categoryLabels}}"
        bindchange="onCategoryChange"
      >
        <view class="picker-row">
          <view>
            <view class="field-label required">装备分类</view>
            <view class="field-value">{{categoryLabels[categoryIndex]}}</view>
            <view class="field-hint">{{categoryHints[categoryIndex]}}</view>
          </view>
          <view class="chevron">›</view>
        </view>
      </picker>
      <view class="field">
        <view class="field-label required">装备名称</view>
        <input
          value="{{form.name}}"
          data-field="name"
          placeholder="例如 NITECORE 头灯"
          bindinput="onInput"
        />
      </view>
      <view class="two-column">
        <view class="field compact">
          <view class="field-label">品牌</view>
          <input
            value="{{form.brand}}"
            data-field="brand"
            placeholder="品牌"
            bindinput="onInput"
          />
        </view>
        <view class="field compact">
          <view class="field-label">型号</view>
          <input
            value="{{form.model}}"
            data-field="model"
            placeholder="型号"
            bindinput="onInput"
          />
        </view>
      </view>
      <view class="two-column">
        <view class="field compact">
          <view class="field-label">颜色</view>
          <input
            value="{{form.color}}"
            data-field="color"
            placeholder="颜色"
            bindinput="onInput"
          />
        </view>
        <view class="field compact">
          <view class="field-label">材质</view>
          <input
            value="{{form.material}}"
            data-field="material"
            placeholder="材质"
            bindinput="onInput"
          />
        </view>
      </view>
      <view class="two-column">
        <view class="field compact">
          <view class="field-label">容量</view>
          <input
            value="{{form.capacity}}"
            data-field="capacity"
            placeholder="如 20000mAh"
            bindinput="onInput"
          />
        </view>
        <view class="field compact">
          <view class="field-label">尺寸</view>
          <input
            value="{{form.size}}"
            data-field="size"
            placeholder="如 M / 55L"
            bindinput="onInput"
          />
        </view>
      </view>
      <view class="field">
        <view class="field-label">装备描述</view>
        <textarea
          value="{{form.description}}"
          data-field="description"
          placeholder="记录用途、亮点或适用场景"
          bindinput="onInput"
        />
      </view>
    </view>

    <view class="form-card">
      <view class="section-title">性能指标</view>
      <view class="field">
        <view class="field-label">重量（kg）</view>
        <input
          value="{{form.weightText}}"
          data-field="weightText"
          type="digit"
          placeholder="例如 0.315"
          bindinput="onInput"
        />
        <view class="field-hint">填写千克数即可，例如 0.315 kg。</view>
      </view>
      <view class="two-column">
        <view class="field compact">
          <view class="field-label">保暖指数</view>
          <input
            value="{{form.warmthIndex}}"
            data-field="warmthIndex"
            placeholder="如 -10℃"
            bindinput="onInput"
          />
        </view>
        <view class="field compact">
          <view class="field-label">防水指数</view>
          <input
            value="{{form.waterproofIndex}}"
            data-field="waterproofIndex"
            placeholder="如 IPX8"
            bindinput="onInput"
          />
        </view>
      </view>
    </view>

    <view class="form-card">
      <view class="section-title">购买与存放</view>
      <view class="two-column">
        <view class="field compact">
          <view class="field-label">购买日期</view>
          <input
            value="{{form.purchaseDate}}"
            data-field="purchaseDate"
            placeholder="YYYY-MM-DD"
            bindinput="onInput"
          />
        </view>
        <view class="field compact">
          <view class="field-label">购买价格（元）</view>
          <input
            value="{{form.purchasePriceText}}"
            data-field="purchasePriceText"
            type="digit"
            placeholder="639.50"
            bindinput="onInput"
          />
        </view>
      </view>
      <view class="two-column">
        <view class="field compact">
          <view class="field-label">保修/到期</view>
          <input
            value="{{form.expiryOrWarrantyDate}}"
            data-field="expiryOrWarrantyDate"
            placeholder="YYYY-MM-DD"
            bindinput="onInput"
          />
        </view>
        <view class="field compact">
          <view class="field-label">购买渠道</view>
          <input
            value="{{form.purchaseLocation}}"
            data-field="purchaseLocation"
            placeholder="京东 / 门店"
            bindinput="onInput"
          />
        </view>
      </view>
      <picker
        value="{{statusIndex}}"
        range="{{statusLabels}}"
        bindchange="onStatusChange"
      >
        <view class="picker-row">
          <view>
            <view class="field-label">装备状态</view>
            <view class="field-value">{{statusLabels[statusIndex]}}</view>
          </view>
          <view class="chevron">›</view>
        </view>
      </picker>
      <view class="field">
        <view class="field-label">存放位置</view>
        <input
          value="{{form.storageLocation}}"
          data-field="storageLocation"
          placeholder="例如 装备柜 A1"
          bindinput="onInput"
        />
      </view>
    </view>

    <view class="form-card">
      <view class="section-title">标签与共享</view>
      <view class="field">
        <view class="field-label">标签</view>
        <input
          value="{{form.tagsText}}"
          data-field="tagsText"
          placeholder="用逗号分隔，如 冬季, 电子"
          bindinput="onInput"
        />
      </view>
      <view class="switch-row">
        <view>
          <view class="field-label">允许共享给搭子参考</view>
          <view class="field-hint"
            >可以先标记为愿意分享，之后方便给搭子参考。</view
          >
        </view>
        <switch
          checked="{{form.shareEnabled}}"
          color="#0f766e"
          bindchange="onShareSwitch"
        />
      </view>
      <view class="field">
        <view class="field-label">备注</view>
        <textarea
          value="{{form.notes}}"
          data-field="notes"
          placeholder="保养、充电、耗材补充等提醒"
          bindinput="onInput"
        />
      </view>
    </view>
  </block>

  <view wx:if="{{loginPrompt.visible}}" class="login-prompt-mask">
    <view class="login-prompt-card">
      <view class="login-prompt-close" bindtap="loginPromptClose">×</view>
      <view class="login-prompt-title">{{loginPrompt.title}}</view>
      <view class="login-prompt-message">{{loginPrompt.message}}</view>
      <view class="login-prompt-actions">
        <button class="secondary" bindtap="loginPromptClose">暂不登录</button>
        <button class="primary" bindtap="loginPromptGoLogin">去登录</button>
      </view>
    </view>
  </view>
</view>

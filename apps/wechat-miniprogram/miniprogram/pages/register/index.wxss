.register-page {
  min-height: 100vh;
  padding: 32rpx;
  background: var(--page-bg);
  color: var(--text-color);
  box-sizing: border-box;
}

.register-page.theme-dark {
  background: var(--body-gradient);
}

.register-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
}

.register-card.hero {
  color: #0f172a;
  background: var(--hero-surface-gradient);
  box-shadow: var(--hero-surface-shadow);
  border: 1rpx solid var(--hero-surface-border);
  border-radius: var(--hero-card-radius);
}

.eyebrow {
  color: var(--accent-color);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.title {
  margin-top: 12rpx;
  color: var(--text-color);
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.35;
}

.subtitle {
  margin-top: 12rpx;
  color: var(--muted-color);
  font-size: 26rpx;
  line-height: 1.58;
}

.section-title {
  color: var(--text-color);
  font-size: 30rpx;
  font-weight: 900;
}

.field-label {
  display: block;
  margin: 22rpx 0 10rpx;
  color: var(--heading-muted-color);
  font-size: 24rpx;
  font-weight: 900;
}

.field-input {
  min-height: 78rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--control-border);
  border-radius: 22rpx;
  color: var(--text-color);
  background: var(--control-bg);
  font-size: 27rpx;
  box-sizing: border-box;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.code-button {
  flex: 0 0 190rpx;
  margin: 0;
  border-radius: 22rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 78rpx;
}

.error-text,
.notice-text {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.error-text {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
}

.notice-text {
  color: var(--status-success-text);
  background: var(--status-success-bg);
}

button.primary,
button.secondary {
  width: 100%;
  margin-top: 24rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 82rpx;
}

button.primary {
  color: var(--brand-text-color);
  background: var(--brand-color);
}

button.secondary {
  color: var(--soft-control-text);
  background: var(--soft-control-bg);
}

.register-page.theme-dark .register-card.hero,
.register-page.theme-dark .title {
  color: #ffffff;
}

.register-page.theme-dark .eyebrow {
  color: rgba(221, 214, 254, 0.92);
}

.register-page.theme-dark .subtitle {
  color: rgba(255, 255, 255, 0.82);
}

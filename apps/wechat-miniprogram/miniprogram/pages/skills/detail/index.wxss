.skill-detail-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 64rpx;
  background: var(--page-bg);
  color: var(--text-color);
  box-sizing: border-box;
}

.skill-detail-page.theme-dark {
  background: var(--body-gradient);
}

.detail-hero,
.state-card,
.info-card {
  border: 1rpx solid var(--border-color);
  border-radius: var(--card-radius);
  background: var(--surface-color);
  box-shadow: var(--shadow-soft);
  color: var(--text-color);
}

.detail-hero {
  overflow: hidden;
}

.media-stage {
  background: #020617;
}

.media-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 430rpx;
  margin: 0 72rpx;
  background: #f8fafc;
}

.stage-image {
  display: block;
  width: 100%;
  height: 100%;
}

.stage-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: var(--muted-color);
  font-size: 26rpx;
  font-weight: 800;
}

.media-toolbar {
  display: flex;
  justify-content: center;
  gap: 34rpx;
  padding: 20rpx 28rpx 12rpx;
}

.media-control {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  margin: 0;
  padding: 0;
  border-radius: 14rpx;
  color: #ffffff;
  background: transparent;
  font-weight: 800;
  line-height: 1;
}

.media-control.active {
  background: rgba(255, 255, 255, 0.22);
}

.media-control-icon {
  font-size: 32rpx;
  line-height: 34rpx;
}

.media-control-label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 18rpx;
  line-height: 20rpx;
}

.media-help {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 0 28rpx 24rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
}

.media-help-name {
  color: #ffffff;
  font-weight: 900;
}

.media-control::after,
.retry-button::after {
  border: 0;
}

.detail-summary-panel {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  justify-content: space-between;
  padding: 34rpx;
}

.detail-copy {
  min-width: 0;
  flex: 1;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: var(--status-info-text);
  background: var(--status-info-bg);
  font-size: 21rpx;
  font-weight: 800;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.tag.success {
  color: var(--status-success-text);
  background: var(--status-success-bg);
}

.tag.warning {
  color: var(--status-warning-text);
  background: var(--status-warning-bg);
}

.tag.danger {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
}

.detail-title {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.35;
}

.detail-summary,
.detail-meta {
  margin-top: 12rpx;
  color: var(--muted-color);
  font-size: 26rpx;
  line-height: 1.58;
}

.difficulty-pill {
  flex: 0 0 auto;
  margin-top: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: var(--status-info-text);
  background: var(--status-info-bg);
  font-size: 24rpx;
  font-weight: 900;
}

.difficulty-pill.success {
  color: var(--status-success-text);
  background: var(--status-success-bg);
}

.difficulty-pill.warning {
  color: var(--status-warning-text);
  background: var(--status-warning-bg);
}

.difficulty-pill.danger {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
}

.state-card,
.info-card {
  margin-top: 24rpx;
  padding: 30rpx;
}

.state-card {
  color: var(--muted-color);
  font-size: 26rpx;
  line-height: 1.6;
  text-align: center;
}

.state-card.error {
  color: var(--status-danger-text);
  background: var(--status-danger-bg);
}

.retry-button {
  margin: 20rpx auto 0;
  padding: 0 32rpx;
  border-radius: 999rpx;
  color: var(--brand-text-color);
  background: var(--brand-color);
  font-size: 25rpx;
  font-weight: 800;
  line-height: 66rpx;
}

.section-title {
  color: var(--text-color);
  font-size: 30rpx;
  font-weight: 900;
}

.paragraph {
  margin-top: 16rpx;
  color: var(--muted-color);
  font-size: 26rpx;
  line-height: 1.7;
}

.skill-detail-page.theme-dark .media-frame {
  background: #f8fafc;
}

# Copy to .env.local for real Web builds. .env.local is ignored by Git.
# Local Vite development uses same-origin /api/v1 by default and proxies it to
# VITE_STELLARTRAIL_API_PROXY_TARGET to avoid browser CORS failures.
VITE_STELLARTRAIL_API_BASE_URL=https://api.example.invalid
VITE_STELLARTRAIL_API_PROXY_TARGET=https://api.example.invalid
VITE_STELLARTRAIL_ASSETS_BASE_URL=https://assets.example.invalid

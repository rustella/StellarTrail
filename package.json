{
  "name": "stellartrail-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "npm run check --workspaces --if-present",
    "format:check": "prettier --check --ignore-unknown \"**/*.{json,md,yml,yaml,ts,tsx,js,wxss,wxml}\"",
    "knots:audit-risk-copy": "node scripts/audit-knot-risk-copy.mjs",
    "knots:upload-media": "node scripts/upload-knots3d-media.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}

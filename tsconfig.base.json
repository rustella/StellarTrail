{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@stellartrail/api-client": ["packages/api-client-ts/src/index.ts"],
      "@stellartrail/shared-types": ["packages/shared-types/src/index.ts"]
    }
  }
}

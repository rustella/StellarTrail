# API
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8080
RUST_LOG=stellartrail_api=debug,tower_http=debug,info

# Database URL examples:
# DATABASE_URL=sqlite://stellartrail.db
# DATABASE_URL=postgres://stellartrail:example-password@localhost:15432/stellartrail
DATABASE_URL=sqlite://stellartrail.db

# WeChat Mini Program login.
# Production real login requires both WECHAT_APP_ID and WECHAT_APP_SECRET.
WECHAT_APP_ID=change-me
WECHAT_APP_SECRET=change-me
# Local-only mock login for development. Set false outside local mock environments.
WECHAT_MOCK_LOGIN=true

# Redis cache (optional; leave REDIS_URL empty to disable server-side cache).
# Docker Compose default: redis://127.0.0.1:local-redis-password@0
REDIS_URL=
REDIS_KEY_PREFIX=stellartrail
REDIS_GEAR_CACHE_TTL_SECONDS=30

# Feedback upload limits.
UPLOAD_MAX_IMAGE_BYTES=8000000
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=3600
UPLOAD_MAX_IMAGES_PER_WINDOW=30
UPLOAD_MAX_TOTAL_IMAGES_PER_USER=100
UPLOAD_MAX_TOTAL_BYTES_PER_USER=200000000

# CORS. Comma-separate multiple origins; leave empty for same-origin/local API usage.
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# Shared MinIO/S3-compatible connection. Private feedback uploads and public
# Knots3D media buckets both reuse this endpoint and credential set.
MINIO_ENDPOINT=http://127.0.0.1:19000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
MINIO_FORCE_PATH_STYLE=true

# Private image uploads for feedback.
OBJECT_STORAGE_BUCKET=stellartrail-uploads

# Public profile avatar images.
AVATAR_STORAGE_BUCKET=stellartrail-avatars
AVATAR_STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:19000/stellartrail-avatars
AVATAR_STORAGE_MAX_IMAGE_BYTES=2000000

# Public Knots3D media objects. Public URLs are stored in DB media_resources.
KNOTS_MEDIA_STORAGE_PROFILE=knots-public
KNOTS_MEDIA_BUCKET=stellartrail-knots-media
KNOTS_MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:19000/stellartrail-knots-media
KNOTS_MEDIA_MAX_IMAGE_BYTES=32000000
KNOTS_MEDIA_MAX_VIDEO_BYTES=80000000

# Global route rate limit. Non-OPTIONS requests are limited by client IP;
# authenticated requests are also limited by user id. Only trust forwarded
# client IP headers when the direct peer is a configured reverse proxy.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS_PER_IP=120
RATE_LIMIT_MAX_REQUESTS_PER_USER=240
RATE_LIMIT_TRUST_PROXY_HEADERS=false
RATE_LIMIT_TRUSTED_PROXY_CIDRS=

# Public read API protection and response cache.
PUBLIC_API_RATE_LIMIT_ENABLED=true
PUBLIC_API_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_API_RATE_LIMIT_MAX_REQUESTS_PER_IP=120
PUBLIC_API_CACHE_TTL_SECONDS=300
PUBLIC_API_CACHE_STALE_SECONDS=600
PUBLIC_API_MAX_LIST_LIMIT=100
PUBLIC_API_MAX_SEARCH_QUERY_CHARS=64
PUBLIC_API_MAX_OFFSET=10000
PUBLIC_API_TRUST_PROXY_HEADERS=false
PUBLIC_API_TRUSTED_PROXY_CIDRS=

# Transactional email delivery for registration, login, and password reset codes.
# This example uses smtp.example.invalid; keep the real SMTP username, sender,
# and password in local .env/config.yaml or a secret manager, never in Git.
MAIL_ENABLED=false
MAIL_SMTP_HOST=smtp.example.invalid
MAIL_SMTP_PORT=465
MAIL_SMTP_TLS=implicit
MAIL_SMTP_USERNAME=[REDACTED]
MAIL_SMTP_PASSWORD=[REDACTED]
MAIL_FROM="StellarTrail <[REDACTED]>"
MAIL_VERIFICATION_SUBJECT=寻径星野邮箱验证码

# Docker Compose local ports. Override if host ports are occupied.
API_HOST_PORT=18080
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
MYSQL_HOST_PORT=13306

# Persistent shared test-environment data root. Use this only with
# infra/test/docker-compose.shared-data.yml; integration-test.sh intentionally
# creates disposable volumes and removes them after the smoke test.
STELLARTRAIL_TEST_DATA_ROOT=/data00/home/wx.xw/stellartrail/shared-test-data

# Docker Compose local-only MinIO bootstrap credentials.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Optional Knots3D metadata input for media upload and verification.
KNOTS3D_METADATA_PATH=.hermes/local/knots3d/metadata/knots3d_bilingual_metadata.json

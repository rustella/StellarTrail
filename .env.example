# API
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8080
RUST_LOG=stellartrail_api=debug,tower_http=debug,info
CONTENT_DIR=content
# CONTENT_ASSETS_DIR is still available for legacy static content; knots media must use MinIO + DB URLs.
CONTENT_ASSETS_DIR=content/assets
MEDIA_BASE_URL=/assets
KNOTS3D_METADATA_PATH=.hermes/local/knots3d/metadata/knots3d_bilingual_metadata.json

# Database URL examples:
# DATABASE_URL=sqlite://stellartrail.db
# DATABASE_URL=postgres://stellartrail:stellartrail@localhost:15432/stellartrail
# DATABASE_URL=mysql://stellartrail:stellartrail@localhost:13306/stellartrail
DATABASE_URL=sqlite://stellartrail.db

# WeChat Mini Program login
# Production real login requires both WECHAT_APP_ID and WECHAT_APP_SECRET.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# Local-only mock login for development. Set false outside local mock environments.
WECHAT_MOCK_LOGIN=true

# Redis cache (optional; leave REDIS_URL empty to disable server-side cache).
# Docker Compose default: redis://127.0.0.1:16379/0
REDIS_URL=
REDIS_KEY_PREFIX=stellartrail
REDIS_GEAR_CACHE_TTL_SECONDS=30

# Public unauthenticated read APIs (/api/skills, /api/skills/knots/*).
# Keep proxy headers disabled unless the direct peer is a trusted reverse proxy.
PUBLIC_API_RATE_LIMIT_ENABLED=true
PUBLIC_API_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_API_RATE_LIMIT_MAX_REQUESTS_PER_IP=120
PUBLIC_API_CACHE_TTL_SECONDS=300
PUBLIC_API_CACHE_STALE_SECONDS=600
PUBLIC_API_MAX_LIST_LIMIT=100
PUBLIC_API_MAX_SEARCH_QUERY_CHARS=64
PUBLIC_API_MAX_OFFSET=10000
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=

# Shared MinIO/S3-compatible connection. The two business buckets below reuse this endpoint and credential set.
MINIO_ENDPOINT=http://127.0.0.1:19000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
MINIO_FORCE_PATH_STYLE=true

# Private image uploads for feedback.
OBJECT_STORAGE_BUCKET=stellartrail-uploads

# Public Knots3D media uploads. Binary data is stored in MinIO/S3-compatible storage;
# public read APIs return KNOTS_MEDIA_PUBLIC_BASE_URL + object key from DB metadata.
KNOTS_MEDIA_STORAGE_PROFILE=knots-public
KNOTS_MEDIA_BUCKET=stellartrail-knots-media
KNOTS_MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:19000/stellartrail-knots-media
KNOTS_MEDIA_MAX_IMAGE_BYTES=32000000
KNOTS_MEDIA_MAX_VIDEO_BYTES=80000000

# Administrator allowlist for /api/admin/* routes. At least one of these values must match
# the authenticated user id/email/username used by the upload CLI.
ADMIN_USER_IDS=
ADMIN_EMAILS=
ADMIN_USERNAMES=
STELLARTRAIL_ADMIN_TOKEN=
STELLARTRAIL_API_BASE_URL=http://127.0.0.1:8080
KNOTS3D_MEDIA_ROOT=.hermes/local/knots3d
KNOTS3D_UPLOAD_CONCURRENCY=4


# Transactional email delivery for registration verification codes.
# Production uses mx1.stellartrail.cn with noreply@stellartrail.cn; keep the real
# SMTP password in local .env/config.yaml or a secret manager, never in Git.
MAIL_ENABLED=false
MAIL_SMTP_HOST=mx1.stellartrail.cn
MAIL_SMTP_PORT=465
MAIL_SMTP_TLS=implicit
MAIL_SMTP_USERNAME=noreply@stellartrail.cn
MAIL_SMTP_PASSWORD=
MAIL_FROM=寻径星野 <noreply@stellartrail.cn>
MAIL_VERIFICATION_SUBJECT=寻径星野邮箱验证码

# Docker Compose local ports. Override if host ports are occupied.
API_HOST_PORT=18080
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
MINIO_API_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
MYSQL_HOST_PORT=13306

# Docker Compose local-only MinIO bootstrap credentials.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
